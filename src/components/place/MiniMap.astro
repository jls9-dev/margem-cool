---
/**
 * MiniMap — stylised outline of the Setúbal Peninsula with the concelhos
 * roughly traced, the parent concelho subtly filled, and a rust dot for
 * the place itself. The Tejo curves across the top as a rust stroke that
 * echoes the wordmark river.
 *
 * Geometry is editorial-stylised, not cartographically precise. Coordinates
 * for each concelho are an approximation of relative position. Refinement
 * with proper GeoJSON-derived paths is a v2 task; for now the schematic
 * gives the reader instant geographic context, which is the brand point.
 */
interface Props {
  concelhoSlug: string;   // The concelho key (e.g. "almada", "seixal")
  placeSlug: string;      // For dot lookup
  placeName: string;      // For label
}
const { concelhoSlug, placeSlug, placeName } = Astro.props;

// Concelho shapes — simplified polygons in a 0-400 × 0-260 viewBox.
// North is up, west is left. The Tejo runs along the top.
const concelhoPaths: Record<string, string> = {
  almada:    'M 28 56 L 100 50 L 110 100 L 95 145 L 30 130 Z',
  seixal:    'M 100 50 L 165 58 L 165 130 L 95 145 L 110 100 Z',
  barreiro:  'M 165 58 L 215 62 L 215 110 L 165 105 Z',
  moita:     'M 215 62 L 270 60 L 285 100 L 215 110 Z',
  montijo:   'M 270 60 L 350 56 L 360 110 L 285 100 Z',
  alcochete: 'M 350 56 L 388 54 L 388 96 L 360 110 Z',
  palmela:   'M 215 110 L 360 110 L 360 180 L 215 180 Z',
  sesimbra:  'M 30 130 L 95 145 L 165 130 L 200 180 L 145 230 L 60 200 Z',
  setubal:   'M 165 130 L 215 110 L 215 180 L 360 180 L 350 230 L 200 230 L 145 230 L 200 180 Z',
};

// Concelho-centre coordinates — used for place dot fallback when the place
// itself isn't in the placeDots lookup yet.
const concelhoCentres: Record<string, [number, number]> = {
  almada: [70, 95],
  seixal: [130, 100],
  sesimbra: [115, 185],
  setubal: [275, 195],
  palmela: [290, 140],
  barreiro: [190, 85],
  moita: [240, 85],
  montijo: [315, 85],
  alcochete: [370, 80],
};

// Place-specific dot coordinates — extends over time. Initial entries cover
// the worked examples (Cacilhas, Belverde). Slugs are full place.slug values.
const placeDots: Record<string, [number, number]> = {
  'almada/almada-cova-da-piedade-pragal-e-cacilhas/cacilhas': [75, 60],
  'seixal/amora/belverde': [140, 115],
};

const dot = placeDots[placeSlug] ?? concelhoCentres[concelhoSlug] ?? [200, 130];
const parentPath = concelhoPaths[concelhoSlug];

// Tejo path — the brand river gesture at the top, echoing the wordmark
const tejoPath = 'M 0 40 C 60 60, 130 28, 200 42 S 320 52, 400 36';
---

<figure class="minimap" aria-label={`${placeName} on the Margem Sul`}>
  <svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
    <!-- Tejo (brand river curve) -->
    <path
      d={tejoPath}
      fill="none"
      stroke="var(--color-accent)"
      stroke-width="2.5"
      stroke-linecap="round"
      opacity="0.7"
    />

    <!-- All concelhos as faint shapes -->
    {Object.entries(concelhoPaths).map(([slug, d]) => (
      <path
        d={d}
        fill={slug === concelhoSlug ? 'var(--color-accent)' : 'var(--color-text)'}
        fill-opacity={slug === concelhoSlug ? '0.18' : '0.06'}
        stroke="var(--color-text)"
        stroke-width="0.7"
        stroke-opacity="0.5"
      />
    ))}

    <!-- Place dot -->
    <circle
      cx={dot[0]}
      cy={dot[1]}
      r="6"
      fill="var(--color-accent)"
      stroke="var(--color-background)"
      stroke-width="2"
    />
  </svg>
  <figcaption class="minimap__caption smallcaps">{placeName} · Margem Sul</figcaption>
</figure>

<style>
  .minimap {
    margin: 0;
    padding: var(--space-md) 0 0;
    max-width: 320px;
  }
  .minimap svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .minimap__caption {
    display: block;
    margin: var(--space-xs) 0 0;
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
  }
</style>
