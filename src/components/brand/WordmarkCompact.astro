---
/**
 * WordmarkCompact — horizontal "margem cool" wordmark for the slim header.
 * Inlined at build time. Displayed at its natural aspect ratio, nothing
 * cropped or wrapped — the river extends to the right of the letters as
 * the brand mark intends.
 */
import svgSource from '../../../public/wordmark.svg?raw';

interface Props {
  height?: number;
  ariaLabel?: string;
}
const { height = 36, ariaLabel = 'margem cool' } = Astro.props;

// SVG viewBox 869 × 156 → width per unit height = 869/156 = 5.57
const width = Math.round(height * (869 / 156));

const sized = svgSource
  .replace('<svg ', `<svg width="${width}" height="${height}" `)
  .replace('aria-label="margem cool"', `aria-label="${ariaLabel}"`);
---

<Fragment set:html={sized} />
