---
/**
 * Breadcrumb — visual breadcrumb. JSON-LD BreadcrumbList is generated by the
 * layout's JSON-LD utility separately.
 */
interface Crumb {
  href?: string;
  label: string;
}
interface Props {
  ariaLabel: string;
  items: ReadonlyArray<Crumb>;   // items[items.length - 1] is the current page
}
const { ariaLabel, items } = Astro.props;
---

<nav class="place-breadcrumb" aria-label={ariaLabel}>
  <div class="container">
    <ol class="place-breadcrumb__list">
      {items.map((c, i) => (
        <li class="place-breadcrumb__item">
          {c.href && i < items.length - 1
            ? <a href={c.href}>{c.label}</a>
            : <span aria-current="page">{c.label}</span>}
        </li>
      ))}
    </ol>
  </div>
</nav>

<style>
  .place-breadcrumb {
    padding: var(--space-md) 0 0;
    font-family: var(--font-display);
    font-size: var(--type-caption);
    color: var(--color-text-secondary);
  }
  .place-breadcrumb__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    max-width: var(--wide-section);
    margin: 0 auto;
  }
  .place-breadcrumb__item::after {
    content: '·';
    margin-left: var(--space-xs);
    color: var(--color-rule);
  }
  .place-breadcrumb__item:last-child::after { content: ''; }
  .place-breadcrumb__item a {
    border-bottom: 0;
    color: var(--color-text-secondary);
  }
  .place-breadcrumb__item a:hover {
    color: var(--color-accent);
  }
  .place-breadcrumb__item [aria-current="page"] {
    color: var(--color-text);
  }
</style>
