---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact · Margem Cool',
  inLanguage: 'en',
  url: 'https://margemcool.pt/en/contact/',
};
---

<BaseLayout
  lang="en"
  title="Contact · Margem Cool"
  description="How to reach the Margem Cool editors."
  alternateUrl="/contacto/"
  canonicalPath="/en/contact/"
  jsonLd={jsonLd}
>
  <article class="page">
    <div class="container">
      <div class="page__inner">
        <p class="page__kicker smallcaps">Margem Cool</p>
        <h1 class="page__title">Contact</h1>
        <p class="page__lede">
          To reach the editors, write to <a href="mailto:hello@margemcool.pt">hello@margemcool.pt</a>.
        </p>
        <p>
          Corrections, suggestions, places and restaurants and festas we should cover — all welcome. We're always interested in what we're missing on the Margem Sul.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .page { padding: var(--space-2xl) 0 var(--space-3xl); }
  .page__inner { max-width: var(--content-column); margin: 0 auto; }
  .page__kicker { margin: 0 0 var(--space-md); color: var(--color-accent); font-size: var(--type-caption); }
  .page__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--type-h1);
    line-height: var(--leading-headline);
    margin: 0 0 var(--space-lg);
  }
  @media (max-width: 720px) { .page__title { font-size: var(--type-h1-mobile); } }
  .page__lede {
    font-family: var(--font-body);
    font-size: var(--type-lead);
    margin: 0 0 var(--space-lg);
    line-height: 1.5;
  }
</style>
