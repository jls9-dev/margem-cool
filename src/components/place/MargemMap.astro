---
/**
 * MargemMap — interactive map of the Margem Sul's 9 concelhos.
 *
 * Built from real geoapi.pt geometry, simplified with Douglas-Peucker
 * (~125 edges per concelho), projected with latitude-corrected
 * equirectangular into an 800-wide viewBox. The Tejo, Atlantic and Sado
 * are implied by the negative space; we add rust italic labels to name
 * them. Each concelho is a link to its overview page, the current one is
 * filled with the brand teal/rust, and any provided place centroid drops
 * a rust dot on the geography.
 *
 * Sizes:
 *   - 'mini' — hero slot use; outlines only, current concelho highlighted,
 *     place dot present, no permanent labels for the other 8 (hover shows them)
 *   - 'standard' — feature use on concelho pages; all labels visible,
 *     stronger geographic context (Tejo, Atlantic, Sado, Lisboa anchor)
 *
 * Data: src/data/geo/concelhos.json (regenerate via scripts/build-concelhos-geo.mjs)
 */
import geoData from '../../data/geo/concelhos.json';

interface Props {
  size?: 'mini' | 'standard';
  concelhoSlug?: string;     // The concelho to highlight (place's parent)
  placeName?: string;        // For caption + dot accessibility
  placeCentroid?: [number, number];  // [lng, lat] from frontmatter geo.centroid
  lang?: 'pt' | 'en';        // For link URL prefix
}

const {
  size = 'mini',
  concelhoSlug,
  placeName,
  placeCentroid,
  lang = 'pt',
} = Astro.props;

const [vbX, vbY, vbW, vbH] = geoData.viewBox;
const { padding, kLat, scale } = geoData.project;
const { bbox } = geoData;

function project(lng: number, lat: number): [number, number] {
  const x = padding + (lng - bbox.minLng) * kLat * scale;
  const y = padding + (bbox.maxLat - lat) * scale;
  return [x, y];
}

const placeXY = placeCentroid ? project(placeCentroid[0], placeCentroid[1]) : null;

const baseHref = lang === 'en' ? '/en/places' : '/lugares';

const isStandard = size === 'standard';

// Landmark anchors — projected once. PT/EN labels chosen by `lang` prop.
type Landmark = { lng: number; lat: number; pt: string; en: string; dx?: number; dy?: number };
const landmarks: Landmark[] = [
  { lng: -9.1697, lat: 38.6772, pt: 'Cristo Rei', en: 'Cristo Rei',   dx: -8, dy: 10 },
  { lng: -9.2148, lat: 38.4138, pt: 'Cabo Espichel', en: 'Cabo Espichel', dx: 10, dy: 6 },
  { lng: -8.9783, lat: 38.4783, pt: 'Serra da Arrábida', en: 'Serra da Arrábida', dx: 0, dy: -10 },
  { lng: -8.9019, lat: 38.5672, pt: 'Castelo de Palmela', en: 'Palmela castle',  dx: 0, dy: -10 },
];
const projectedLandmarks = landmarks.map((m) => ({
  ...m,
  xy: project(m.lng, m.lat),
}));

// Bilingual water labels (Tejo, Atlantic, Sado). EN gets the international forms.
const waterLabels = {
  tejo:     lang === 'en' ? 'Tagus'          : 'Tejo',
  atlantic: lang === 'en' ? 'Atlantic Ocean' : 'Oceano Atlântico',
  sado:     lang === 'en' ? 'Sado Estuary'   : 'Estuário do Sado',
};
---

<figure class={`margem-map margem-map--${size}`} aria-label={`Mapa da Margem Sul${placeName ? ` — ${placeName}` : ''}`}>
  <svg
    viewBox={`${vbX} ${vbY} ${vbW} ${vbH}`}
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-hidden="false"
    overflow="hidden"
  >
    <defs>
      <filter id="dot-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    {/* Water base — brand teal at low opacity. Land shapes (concelhos +
        context_north) draw over this with a solid land tone so the teal
        shows through only in the actual sea / river / estuary. */}
    <rect x={vbX} y={vbY} width={vbW} height={vbH} class="water-base" />

    {/* Lisbon + Oeiras — north-of-the-Tejo context outline. Faint enough
        to read as "the other side", clear enough to orient the viewer. */}
    <g class="context-north">
      {geoData.context_north.map((c) => c.paths.map((d) => (
        <path d={d} class="context-shape" />
      )))}
      {/* Always-on "Lisboa" anchor label inside the Lisbon outline, so even
          in mini mode the viewer knows what they're looking at. */}
      <text
        x={project(-9.1430, 38.7440)[0]}
        y={project(-9.1430, 38.7440)[1]}
        class="context-label"
        text-anchor="middle"
      >
        {lang === 'en' ? 'Lisbon' : 'Lisboa'}
      </text>
    </g>

    {/* Water labels — set in the negative space between the two coasts.
        Tejo positioned at lat/lng so it lands in actual water (between
        Almada and Lisbon), not on top of land. */}
    {isStandard && (
      <g class="map-water-labels">
        <text
          x={project(-9.105, 38.708)[0]}
          y={project(-9.105, 38.708)[1]}
          class="water-label water-label--major"
          text-anchor="middle"
        >
          {waterLabels.tejo}
        </text>
        <text x={vbW * 0.04} y={vbH * 0.55} class="water-label" transform={`rotate(-90 ${vbW * 0.04} ${vbH * 0.55})`}>
          {waterLabels.atlantic}
        </text>
        <text x={vbW * 0.55} y={vbH * 0.96} class="water-label">
          {waterLabels.sado}
        </text>
      </g>
    )}

    {/* Concelho polygons — each wrapped in a link */}
    <g class="concelhos">
      {geoData.concelhos.map((c) => {
        const isCurrent = c.slug === concelhoSlug;
        return (
          <a href={`${baseHref}/${c.slug}/`} class={`concelho-link ${isCurrent ? 'is-current' : ''}`}>
            <title>{c.name}{isStandard ? ` — ${c.area_km2.toFixed(0)} km² · ${c.population_2021?.toLocaleString('pt-PT')} habitantes` : ''}</title>
            {c.paths.map((d) => (
              <path
                d={d}
                class={`concelho ${isCurrent ? 'is-current' : ''}`}
              />
            ))}
            {/* Label always visible for current; on hover for others */}
            <text
              x={c.labelXY[0]}
              y={c.labelXY[1]}
              class={`concelho-label ${isCurrent ? 'is-current' : ''} ${isStandard ? 'is-standard' : ''}`}
              text-anchor="middle"
              dominant-baseline="middle"
            >
              {c.name}
            </text>
          </a>
        );
      })}
    </g>

    {/* Landmarks — small rust dots + labels. Standard only. */}
    {isStandard && (
      <g class="landmarks">
        {projectedLandmarks.map((m) => (
          <g>
            <circle cx={m.xy[0]} cy={m.xy[1]} r="3.5" class="landmark-dot" />
            <text
              x={m.xy[0] + (m.dx ?? 8)}
              y={m.xy[1] + (m.dy ?? -8)}
              class="landmark-label"
              text-anchor={(m.dx ?? 0) < 0 ? 'end' : 'start'}
            >
              {lang === 'en' ? m.en : m.pt}
            </text>
          </g>
        ))}
      </g>
    )}

    {/* Place dot — drawn last so it sits on top */}
    {placeXY && (
      <g class="place-marker">
        <circle
          cx={placeXY[0]}
          cy={placeXY[1]}
          r="14"
          class="place-marker__halo"
        />
        <circle
          cx={placeXY[0]}
          cy={placeXY[1]}
          r="6"
          class="place-marker__dot"
        />
        <circle
          cx={placeXY[0]}
          cy={placeXY[1]}
          r="2.5"
          class="place-marker__core"
        />
      </g>
    )}
  </svg>

  {placeName && (
    <figcaption class="margem-map__caption smallcaps">
      {placeName} · Margem Sul
    </figcaption>
  )}
</figure>

<script>
  // Tap-to-reveal-name pattern on touch devices: first tap on a concelho
  // shows its name and highlights it, the second tap on the same concelho
  // navigates. On a different concelho the selection moves and you still
  // need a second tap. Desktop (hover capable) keeps single-click navigation.
  (() => {
    if (typeof window === 'undefined') return;
    const touch = window.matchMedia('(hover: none)').matches;
    if (!touch) return;
    document.querySelectorAll('.margem-map').forEach((map) => {
      const links = map.querySelectorAll('.concelho-link');
      links.forEach((link) => {
        link.addEventListener('click', (event) => {
          if (link.classList.contains('is-tapped') || link.classList.contains('is-current')) {
            return; // second tap (or tap on current) — let navigation through
          }
          event.preventDefault();
          links.forEach((l) => l.classList.remove('is-tapped'));
          link.classList.add('is-tapped');
        });
      });
      // Tap outside any concelho clears the highlight.
      map.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest('.concelho-link')) return;
        links.forEach((l) => l.classList.remove('is-tapped'));
      });
    });
  })();
</script>

<style>
  .margem-map {
    margin: 0;
    padding: 0;
  }
  .margem-map--mini {
    max-width: 360px;
  }
  .margem-map--standard {
    max-width: 720px;
    margin: 0 auto;
  }
  .margem-map svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ──────── Water base + concelho fills ──────── */
  /* The water base is a faint teal wash. Land shapes draw OVER it with a
     solid warm-grey fill so the teal only reads in the sea / river. */
  .water-base {
    fill: color-mix(in srgb, var(--mc-teal) 14%, var(--color-background));
  }
  .concelho {
    fill: color-mix(in srgb, var(--color-text) 9%, var(--color-background));
    stroke: var(--color-text);
    stroke-opacity: 0.55;
    stroke-width: 1;
    stroke-linejoin: round;
    transition: fill 200ms ease, stroke-opacity 200ms ease;
  }
  .concelho-link {
    cursor: pointer;
    outline: none;
  }
  .concelho-link:hover .concelho,
  .concelho-link:focus-visible .concelho,
  .concelho-link.is-tapped .concelho {
    fill: color-mix(in srgb, var(--color-accent) 18%, var(--color-background));
    stroke-opacity: 0.7;
  }
  .concelho.is-current {
    fill: color-mix(in srgb, var(--color-accent) 32%, var(--color-background));
    stroke: var(--color-accent);
    stroke-opacity: 0.8;
    stroke-width: 1.4;
  }
  .concelho-link.is-current:hover .concelho,
  .concelho-link.is-current.is-tapped .concelho {
    fill: color-mix(in srgb, var(--color-accent) 40%, var(--color-background));
  }

  /* ──────── Concelho labels ──────── */
  /* Hidden via `opacity` (not `fill-opacity`), so the cream paint-order
     stroke doesn't ghost through. Become visible on hover, tap, or
     when this concelho is the current page. */
  .concelho-label {
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    fill: var(--color-text);
    fill-opacity: 0.9;
    pointer-events: none;
    paint-order: stroke;
    stroke: var(--color-background);
    stroke-width: 3px;
    stroke-linejoin: round;
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .concelho-link:hover .concelho-label,
  .concelho-link:focus-visible .concelho-label,
  .concelho-link.is-tapped .concelho-label {
    opacity: 1;
  }
  .concelho-label.is-current {
    fill: var(--color-accent);
    opacity: 1;
    font-size: 14px;
    font-weight: 600;
  }
  .concelho-label.is-standard.is-current {
    font-size: 14px;
  }

  /* ──────── North-of-the-Tejo context (Cascais, Oeiras, Lisboa, Loures) ──────── */
  /* Same land tone as the concelhos, opaque so the water doesn't bleed
     through. Slightly lighter than concelho-fill since these are context. */
  .context-shape {
    fill: color-mix(in srgb, var(--color-text) 7%, var(--color-background));
    stroke: var(--color-text);
    stroke-opacity: 0.55;
    stroke-width: 1;
    stroke-linejoin: round;
  }
  .margem-map--standard .context-shape {
    stroke-opacity: 0.6;
    stroke-width: 1.2;
  }
  .context-label {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    fill: var(--color-text);
    fill-opacity: 0.55;
    pointer-events: none;
  }
  .margem-map--standard .context-label {
    font-size: 13px;
    fill-opacity: 0.7;
  }

  /* ──────── Landmarks (standard mode only) ──────── */
  .landmark-dot {
    fill: var(--color-accent);
    fill-opacity: 0.9;
    stroke: var(--color-background);
    stroke-width: 1;
  }
  .landmark-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 11px;
    fill: var(--color-text);
    fill-opacity: 0.85;
    paint-order: stroke;
    stroke: var(--color-background);
    stroke-width: 3px;
    stroke-linejoin: round;
    pointer-events: none;
  }

  /* ──────── Water labels ──────── */
  .water-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    letter-spacing: 0.08em;
    fill: var(--color-accent);
    fill-opacity: 0.55;
    pointer-events: none;
  }
  .water-label--major {
    font-size: 28px;
    fill-opacity: 0.65;
  }
  .anchor-label {
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    fill: var(--color-text);
    fill-opacity: 0.4;
    pointer-events: none;
  }

  /* ──────── Place marker ──────── */
  .place-marker__halo {
    fill: var(--color-accent);
    fill-opacity: 0.12;
    animation: place-pulse 2.8s ease-in-out infinite;
  }
  .place-marker__dot {
    fill: var(--color-accent);
    stroke: var(--color-background);
    stroke-width: 2;
  }
  .place-marker__core {
    fill: var(--color-background);
  }
  @keyframes place-pulse {
    0%, 100% { transform: scale(1); opacity: 0.55; transform-origin: center; transform-box: fill-box; }
    50% { transform: scale(1.35); opacity: 0.18; transform-origin: center; transform-box: fill-box; }
  }
  @media (prefers-reduced-motion: reduce) {
    .place-marker__halo { animation: none; }
  }

  /* ──────── Caption ──────── */
  .margem-map__caption {
    display: block;
    margin: var(--space-xs) 0 0;
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
  }
</style>
