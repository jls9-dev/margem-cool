---
/**
 * Wordmark — stacked "margem cool" mark with the l descending into the river.
 * Inlined at build time so the CSS classes inside the SVG (charcoal letters,
 * rust l-stem and river, dark-mode variants) actually apply in the browser.
 */
import svgSource from '../../../public/wordmark-stacked.svg?raw';

interface Props {
  size?: number;
  ariaLabel?: string;
}
const { size = 360, ariaLabel = 'margem cool' } = Astro.props;

const sized = svgSource
  .replace('<svg ', `<svg width="${size}" `)
  .replace('aria-label="margem cool"', `aria-label="${ariaLabel}"`);
---

<Fragment set:html={sized} />
