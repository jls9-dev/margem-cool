---
/**
 * Wordmark — the full stacked "margem cool" mark with the l descending into
 * the river. Loaded from /public/wordmark-stacked.svg so the letterforms
 * render identically everywhere with no webfont dependency.
 */
interface Props {
  size?: number;
  ariaLabel?: string;
}
const { size = 360, ariaLabel = 'margem cool' } = Astro.props;

// SVG intrinsic viewBox is 502 × 235 — width matches and height scales.
const aspectH = 235 / 502;
const height = Math.round(size * aspectH);
---

<img
  class="mc-wordmark"
  src="/wordmark-stacked.svg"
  width={size}
  height={height}
  alt={ariaLabel}
  decoding="async"
/>

<style>
  .mc-wordmark { display: block; }
</style>
