---
/**
 * FAQ — list of Q&A using native <details>/<summary>. JSON-LD FAQPage entity
 * is generated by src/utils/schema-org.ts at the layout level so we don't
 * duplicate the markup here.
 *
 * Hidden entirely if there are no FAQs to show.
 */
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  kicker: string;
  title: string;
  items?: ReadonlyArray<FAQItem>;
}
const { kicker, title, items = [] } = Astro.props;
if (items.length === 0) return null;
---

<section class="faq" aria-labelledby="faq-h">
  <div class="container">
    <div class="faq__inner">
      <header class="faq__header">
        <p class="faq__kicker smallcaps">{kicker}</p>
        <h2 id="faq-h" class="faq__title">{title}</h2>
      </header>
      <div class="faq__items">
        {items.map((item) => (
          <details class="faq__item">
            <summary class="faq__question">{item.question}</summary>
            <div class="faq__answer"><p>{item.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    padding: var(--space-2xl) 0;
    background: color-mix(in srgb, var(--mc-cream) 60%, transparent);
  }
  @media (prefers-color-scheme: dark) {
    .faq {
      background: color-mix(in srgb, var(--mc-charcoal) 60%, transparent);
    }
  }
  .faq__inner {
    max-width: var(--content-column);
    margin: 0 auto;
  }
  .faq__kicker {
    margin: 0 0 var(--space-sm);
    color: var(--color-accent);
    font-size: var(--type-caption);
  }
  .faq__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--type-h2);
    line-height: var(--leading-headline);
    margin: 0 0 var(--space-xl);
  }
  @media (max-width: 720px) {
    .faq__title { font-size: var(--type-h2-mobile); }
  }
  .faq__item {
    border-top: 1px solid var(--color-rule);
    padding: var(--space-md) 0;
  }
  .faq__item:last-child { border-bottom: 1px solid var(--color-rule); }
  .faq__question {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--type-lead);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: var(--space-lg);
    color: var(--color-text);
  }
  .faq__question::-webkit-details-marker { display: none; }
  .faq__question::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    font-size: var(--type-lead);
    line-height: 1;
    color: var(--color-accent);
    transition: transform 200ms ease;
  }
  .faq__item[open] .faq__question::after {
    content: '−';
  }
  .faq__answer {
    padding-top: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--type-body);
    line-height: var(--leading-body);
    color: var(--color-text-secondary);
  }
  .faq__answer :global(p) { margin: 0 0 var(--space-sm); }
  .faq__answer :global(p:last-child) { margin-bottom: 0; }
</style>
