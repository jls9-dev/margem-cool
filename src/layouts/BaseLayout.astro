---
import '../styles/tokens.css';
import '../styles/base.css';

import WordmarkCompact from '../components/brand/WordmarkCompact.astro';
import Wordmark from '../components/brand/Wordmark.astro';
import { PRIMARY_NAV, htmlLang, SITE_URL, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  /** Path of the equivalent page in the other language, e.g. '/en/' or '/'. */
  alternateUrl?: string;
  /** Canonical path of this page, relative to the site root. */
  canonicalPath?: string;
  /** Optional Schema.org JSON-LD object to inject as a single script tag. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  lang,
  title,
  description,
  alternateUrl,
  canonicalPath = Astro.url.pathname,
  jsonLd,
} = Astro.props;

const nav = PRIMARY_NAV[lang];
const otherLang: Lang = lang === 'pt' ? 'en' : 'pt';
const canonical = new URL(canonicalPath, SITE_URL).toString();
const alternate = alternateUrl
  ? new URL(alternateUrl, SITE_URL).toString()
  : undefined;

const secondaryTagline = lang === 'pt' ? 'O outro lado' : 'The other side';
const copyrightLabel = `© ${new Date().getFullYear()} Margem Cool`;

const footerCopy = {
  pt: {
    newsletterHeading: 'A Margem Sul, na sua caixa de entrada',
    newsletterBody: 'Histórias, lugares e o ritmo do outro lado do Tejo — todas as semanas, sem filtros.',
    emailLabel: 'Endereço de email',
    emailPlaceholder: 'O seu email',
    subscribe: 'Subscrever',
    sectionsHeading: 'Secções',
    destinationsHeading: 'Destinos',
    publicationHeading: 'Margem Cool',
    legalHeading: 'Política de Privacidade · Termos · Cookies',
    columnsLabel: 'Mapa do site',
    privacy: 'Política de Privacidade',
    terms: 'Termos',
    cookies: 'Cookies',
  },
  en: {
    newsletterHeading: 'The Margem Sul, in your inbox',
    newsletterBody: 'Stories, places and the rhythm of the other side of the Tagus — every week, no filter.',
    emailLabel: 'Email address',
    emailPlaceholder: 'Your email',
    subscribe: 'Subscribe',
    sectionsHeading: 'Sections',
    destinationsHeading: 'Destinations',
    publicationHeading: 'Margem Cool',
    legalHeading: 'Privacy Policy · Terms · Cookies',
    columnsLabel: 'Sitemap',
    privacy: 'Privacy Policy',
    terms: 'Terms',
    cookies: 'Cookies',
  },
} as const;

const fc = footerCopy[lang];

const sectionLinks = lang === 'pt'
  ? [
      { href: '/lugares/', label: 'Lugares & Bairros' },
      { href: '/comer-e-beber/', label: 'Comer & Beber' },
      { href: '/praia-e-natureza/', label: 'Praia & Natureza' },
      { href: '/cultura-e-agenda/', label: 'Cultura & Agenda' },
      { href: '/viver-aqui/', label: 'Viver Aqui' },
      { href: '/dormir/', label: 'Dormir' },
    ]
  : [
      { href: '/en/places/', label: 'Places & Neighbourhoods' },
      { href: '/en/eat-and-drink/', label: 'Eat & Drink' },
      { href: '/en/beach-and-outdoors/', label: 'Beach & Outdoors' },
      { href: '/en/culture-and-whats-on/', label: 'Culture & What’s On' },
      { href: '/en/living-here/', label: 'Living Here' },
      { href: '/en/where-to-stay/', label: 'Where to Stay' },
    ];

const destinationLinks = lang === 'pt'
  ? [
      { href: '/lugares/almada/', label: 'Almada' },
      { href: '/lugares/seixal/', label: 'Seixal' },
      { href: '/lugares/setubal/', label: 'Setúbal' },
      { href: '/lugares/sesimbra/', label: 'Sesimbra' },
      { href: '/lugares/almada/costa-da-caparica/', label: 'Costa da Caparica' },
      { href: '/lugares/setubal/arrabida/', label: 'Serra da Arrábida' },
    ]
  : [
      { href: '/en/places/almada/', label: 'Almada' },
      { href: '/en/places/seixal/', label: 'Seixal' },
      { href: '/en/places/setubal/', label: 'Setúbal' },
      { href: '/en/places/sesimbra/', label: 'Sesimbra' },
      { href: '/en/places/almada/costa-da-caparica/', label: 'Costa da Caparica' },
      { href: '/en/places/setubal/arrabida/', label: 'Serra da Arrábida' },
    ];

const publicationLinks = lang === 'pt'
  ? [
      { href: '/sobre/', label: 'Sobre' },
      { href: '/equipa/', label: 'Equipa' },
      { href: '/contacto/', label: 'Contacto' },
      { href: '/sugerir-uma-historia/', label: 'Sugerir uma história' },
      { href: '/parcerias/', label: 'Parcerias' },
    ]
  : [
      { href: '/en/about/', label: 'About' },
      { href: '/en/team/', label: 'Team' },
      { href: '/en/contact/', label: 'Contact' },
      { href: '/en/submit-a-story/', label: 'Submit a story' },
      { href: '/en/partnerships/', label: 'Partnerships' },
    ];
---

<!doctype html>
<html lang={htmlLang(lang)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="canonical" href={canonical} />
    {alternate && (
      <>
        <link rel="alternate" hreflang={htmlLang(otherLang)} href={alternate} />
        <link rel="alternate" hreflang={htmlLang(lang)} href={canonical} />
        <link rel="alternate" hreflang="x-default" href={lang === 'pt' ? canonical : alternate} />
      </>
    )}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={htmlLang(lang).replace('-', '_')} />
    {alternate && (
      <meta property="og:locale:alternate" content={htmlLang(otherLang).replace('-', '_')} />
    )}

    <meta name="twitter:card" content="summary_large_image" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'pt' ? 'Saltar para o conteúdo' : 'Skip to content'}</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href={lang === 'pt' ? '/' : '/en/'} aria-label="Margem Cool">
          <WordmarkCompact height={36} />
        </a>
        <nav class="site-nav" aria-label={lang === 'pt' ? 'Navegação principal' : 'Primary navigation'}>
          <ul>
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={Astro.url.pathname === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        {alternate && (
          <a class="lang-switch smallcaps" href={alternate} hreflang={htmlLang(otherLang)}>
            {otherLang === 'pt' ? 'PT' : 'EN'}
          </a>
        )}
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <section class="site-footer__newsletter" aria-labelledby="footer-newsletter-h">
          <h3 id="footer-newsletter-h" class="site-footer__newsletter-h">{fc.newsletterHeading}</h3>
          <p class="site-footer__newsletter-body">{fc.newsletterBody}</p>
          <form class="site-footer__newsletter-form" action="#" method="post" novalidate>
            <label class="visually-hidden" for="footer-newsletter-email">{fc.emailLabel}</label>
            <input
              id="footer-newsletter-email"
              class="site-footer__newsletter-input"
              type="email"
              name="email"
              placeholder={fc.emailPlaceholder}
              autocomplete="email"
              required
            />
            <button type="submit" class="site-footer__newsletter-button smallcaps">
              {fc.subscribe}
            </button>
          </form>
          <ul class="site-footer__social" aria-label={lang === 'pt' ? 'Redes sociais' : 'Social media'}>
            <li>
              <a href="https://instagram.com/margemcool" rel="me noopener" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" />
                </svg>
              </a>
            </li>
            <li>
              <a href="https://facebook.com/margemcool" rel="me noopener" aria-label="Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                </svg>
              </a>
            </li>
            <li>
              <a href="/rss.xml" aria-label="RSS">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 11a9 9 0 0 1 9 9" />
                  <path d="M4 4a16 16 0 0 1 16 16" />
                  <circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none" />
                </svg>
              </a>
            </li>
          </ul>
        </section>

        <nav class="site-footer__columns" aria-label={fc.columnsLabel}>
          <div class="site-footer__col">
            <h4 class="site-footer__col-h smallcaps">{fc.sectionsHeading}</h4>
            <ul>
              {sectionLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="site-footer__col">
            <h4 class="site-footer__col-h smallcaps">{fc.destinationsHeading}</h4>
            <ul>
              {destinationLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="site-footer__col">
            <h4 class="site-footer__col-h smallcaps">{fc.publicationHeading}</h4>
            <ul>
              {publicationLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        </nav>
      </div>

      <div class="site-footer__signature">
        <div class="site-footer__signature-inner">
          <div class="site-footer__brand">
            <Wordmark size={128} ariaLabel="Margem Cool" />
            <p class="site-footer__tagline smallcaps">{secondaryTagline}</p>
          </div>
          <ul class="site-footer__legal">
            <li><a href={lang === 'pt' ? '/privacidade/' : '/en/privacy/'}>{fc.privacy}</a></li>
            <li><a href={lang === 'pt' ? '/termos/' : '/en/terms/'}>{fc.terms}</a></li>
            <li><a href={lang === 'pt' ? '/cookies/' : '/en/cookies/'}>{fc.cookies}</a></li>
          </ul>
          <p class="site-footer__meta">{copyrightLabel}</p>
        </div>
      </div>
    </footer>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-text);
        color: var(--color-background);
        padding: var(--space-xs) var(--space-sm);
        z-index: 100;
        border-bottom: 0;
      }
      .skip-link:focus { left: var(--space-sm); top: var(--space-sm); }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        padding: 14px 0;
        background: color-mix(in srgb, var(--color-background) 92%, transparent);
        backdrop-filter: saturate(140%) blur(8px);
        -webkit-backdrop-filter: saturate(140%) blur(8px);
        border-bottom: 1px solid var(--color-rule);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        min-height: 40px;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 clamp(16px, 3vw, 40px);
      }
      .site-header__brand {
        border-bottom: 0;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
      }

      .site-nav {
        flex: 1;
        min-width: 0;
      }
      .site-nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--space-sm);
        flex-wrap: nowrap;
        justify-content: flex-end;
      }
      .site-nav a {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 12px;
        letter-spacing: var(--tracking-smallcaps);
        text-transform: uppercase;
        border-bottom: 0;
        color: var(--color-text);
        white-space: nowrap;
      }
      .site-nav a[aria-current="page"] { color: var(--color-accent); }
      .site-nav a:hover { color: var(--color-accent); }

      .lang-switch {
        flex-shrink: 0;
        border: 1px solid var(--color-rule);
        padding: 4px 8px;
        font-size: 11px;
      }
      .lang-switch:hover { border-color: var(--color-accent); }

      @media (max-width: 720px) {
        .site-header { padding: 10px 0; }
        .site-nav ul { gap: 12px; flex-wrap: wrap; }
        .site-nav a { font-size: 11px; }
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .site-footer {
        margin-top: var(--space-3xl);
        border-top: 1px solid var(--color-rule);
        background: var(--color-background);
      }
      .site-footer__inner {
        max-width: 1600px;
        margin: 0 auto;
        padding: var(--space-2xl) clamp(16px, 3vw, 40px);
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 2fr);
        gap: var(--space-2xl);
        align-items: start;
      }

      .site-footer__newsletter {
        max-width: 420px;
      }
      .site-footer__newsletter-h {
        font-family: var(--font-body);
        font-weight: 600;
        font-size: var(--type-h3);
        line-height: var(--leading-headline);
        letter-spacing: -0.01em;
        margin: 0 0 var(--space-sm);
        color: var(--color-text);
      }
      .site-footer__newsletter-body {
        margin: 0 0 var(--space-md);
        font-size: var(--type-small);
        line-height: 1.55;
        color: var(--color-text-secondary);
      }
      .site-footer__newsletter-form {
        display: flex;
        gap: 0;
        border: 1px solid var(--color-rule);
        background: color-mix(in srgb, var(--color-background) 60%, transparent);
        transition: border-color 160ms ease;
      }
      .site-footer__newsletter-form:focus-within {
        border-color: var(--color-accent);
      }
      .site-footer__newsletter-input {
        flex: 1;
        min-width: 0;
        border: 0;
        background: transparent;
        padding: 12px 14px;
        font-family: var(--font-body);
        font-size: var(--type-small);
        color: var(--color-text);
      }
      .site-footer__newsletter-input::placeholder {
        color: var(--color-text-secondary);
        opacity: 0.8;
      }
      .site-footer__newsletter-input:focus { outline: none; }
      .site-footer__newsletter-button {
        border: 0;
        border-left: 1px solid var(--color-rule);
        background: transparent;
        padding: 12px 18px;
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 11px;
        letter-spacing: var(--tracking-smallcaps);
        text-transform: uppercase;
        color: var(--color-text);
        cursor: pointer;
        transition: background-color 160ms ease, color 160ms ease;
      }
      .site-footer__newsletter-button:hover,
      .site-footer__newsletter-button:focus-visible {
        background: var(--color-accent);
        color: var(--mc-cream);
        outline: none;
      }

      .site-footer__social {
        list-style: none;
        margin: var(--space-md) 0 0;
        padding: 0;
        display: flex;
        gap: var(--space-sm);
      }
      .site-footer__social a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--color-rule);
        border-radius: 50%;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color 160ms ease, border-color 160ms ease;
      }
      .site-footer__social a:hover,
      .site-footer__social a:focus-visible {
        color: var(--color-accent);
        border-color: var(--color-accent);
        outline: none;
      }

      .site-footer__columns {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--space-xl);
      }
      .site-footer__col h4 {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 11px;
        letter-spacing: var(--tracking-smallcaps);
        text-transform: uppercase;
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-md);
        padding-bottom: var(--space-xs);
        border-bottom: 1px solid var(--color-rule);
      }
      .site-footer__col ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .site-footer__col a {
        font-family: var(--font-body);
        font-size: var(--type-small);
        color: var(--color-text);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: color 160ms ease, border-color 160ms ease;
      }
      .site-footer__col a:hover,
      .site-footer__col a:focus-visible {
        color: var(--color-accent);
        border-bottom-color: var(--color-accent);
        outline: none;
      }

      .site-footer__signature {
        border-top: 1px solid var(--color-rule);
      }
      .site-footer__signature-inner {
        max-width: 1600px;
        margin: 0 auto;
        padding: var(--space-lg) clamp(16px, 3vw, 40px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-lg);
        flex-wrap: wrap;
      }
      .site-footer__brand {
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }
      .site-footer__tagline {
        margin: 0;
        font-family: var(--font-display);
        font-size: var(--type-masthead-meta);
        letter-spacing: var(--tracking-masthead);
        text-transform: uppercase;
        color: var(--color-text-secondary);
      }
      .site-footer__legal {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--space-md);
        flex-wrap: wrap;
      }
      .site-footer__legal a {
        font-family: var(--font-display);
        font-size: 11px;
        letter-spacing: var(--tracking-smallcaps);
        text-transform: uppercase;
        color: var(--color-text-secondary);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: color 160ms ease, border-color 160ms ease;
      }
      .site-footer__legal a:hover,
      .site-footer__legal a:focus-visible {
        color: var(--color-accent);
        border-bottom-color: var(--color-accent);
        outline: none;
      }
      .site-footer__meta {
        margin: 0;
        font-family: var(--font-display);
        font-size: var(--type-caption);
        color: var(--color-text-secondary);
      }

      @media (max-width: 960px) {
        .site-footer__inner {
          grid-template-columns: 1fr;
          gap: var(--space-xl);
        }
      }
      @media (max-width: 640px) {
        .site-footer__columns {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: var(--space-lg);
        }
        .site-footer__signature-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: var(--space-md);
        }
      }
    </style>
  </body>
</html>
