---
/**
 * MargemMap — interactive map of the Margem Sul's 9 concelhos.
 *
 * Built from real geoapi.pt geometry, simplified with Douglas-Peucker
 * (~125 edges per concelho), projected with latitude-corrected
 * equirectangular into an 800-wide viewBox. The Tejo, Atlantic and Sado
 * are implied by the negative space; we add rust italic labels to name
 * them. Each concelho is a link to its overview page, the current one is
 * filled with the brand teal/rust, and any provided place centroid drops
 * a rust dot on the geography.
 *
 * Sizes:
 *   - 'mini' — hero slot use; outlines only, current concelho highlighted,
 *     place dot present, no permanent labels for the other 8 (hover shows them)
 *   - 'standard' — feature use on concelho pages; all labels visible,
 *     stronger geographic context (Tejo, Atlantic, Sado, Lisboa anchor)
 *
 * Data: src/data/geo/concelhos.json (regenerate via scripts/build-concelhos-geo.mjs)
 */
import geoData from '../../data/geo/concelhos.json';
import landData from '../../data/geo/osm-land.json';
import bridgeData from '../../data/geo/bridges.json';

interface Props {
  size?: 'mini' | 'standard';
  concelhoSlug?: string;     // The concelho to highlight (place's parent)
  placeName?: string;        // For caption + dot accessibility
  placeCentroid?: [number, number];  // [lng, lat] from frontmatter geo.centroid
  lang?: 'pt' | 'en';        // For link URL prefix
}

const {
  size = 'mini',
  concelhoSlug,
  placeName,
  placeCentroid,
  lang = 'pt',
} = Astro.props;

const [vbX, vbY, vbW, vbH] = geoData.viewBox;
const { padding, kLat, scale } = geoData.project;
const { bbox } = geoData;

function project(lng: number, lat: number): [number, number] {
  const x = padding + (lng - bbox.minLng) * kLat * scale;
  const y = padding + (bbox.maxLat - lat) * scale;
  return [x, y];
}

const placeXY = placeCentroid ? project(placeCentroid[0], placeCentroid[1]) : null;

const baseHref = lang === 'en' ? '/en/places' : '/lugares';

const isStandard = size === 'standard';

// Bilingual water labels (Tejo, Atlantic, Sado). EN gets the international forms.
const waterLabels = {
  tejo:     lang === 'en' ? 'Tagus'          : 'Tejo',
  atlantic: lang === 'en' ? 'Atlantic Ocean' : 'Oceano Atlântico',
  sado:     lang === 'en' ? 'Sado Estuary'   : 'Estuário do Sado',
};

// Tejo bridges — real OSM geometry. 25 de Abril is the deck outline as a
// closed polygon; Vasco da Gama is the highway route stitched into one
// polyline. See scripts/build-bridges.mjs.
const bridges = bridgeData.bridges.map((b) => ({
  ...b,
  name: lang === 'en' ? b.en : b.pt,
}));
---

<figure class={`margem-map margem-map--${size}`} aria-label={`Mapa da Margem Sul${placeName ? ` — ${placeName}` : ''}`}>
  <svg
    viewBox={`${vbX} ${vbY} ${vbW} ${vbH}`}
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-hidden="false"
    overflow="hidden"
  >
    <defs>
      <filter id="dot-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    {/* Water base — brand teal at low opacity. Land shapes (concelhos +
        context_north) draw over this with a solid land tone so the teal
        shows through only in the actual sea / river / estuary. */}
    <rect x={vbX} y={vbY} width={vbW} height={vbH} class="water-base" />

    {/* Land outline from the OSM Land Polygons dataset (the same
        coastline-derived land that every OSM tile renderer uses).
        Clipped to viewBox and projected with our equirectangular
        projector. evenodd fill so any enclosed water inside a tile
        polygon (rare for this region) reads as water. */}
    <g class="coast">
      {landData.paths.map((p) => (
        <path d={p.d} class="land-base" fill-rule="evenodd" />
      ))}
      <text
        x={project(-9.1430, 38.7440)[0]}
        y={project(-9.1430, 38.7440)[1]}
        class="context-label"
        text-anchor="middle"
      >
        {lang === 'en' ? 'Lisbon' : 'Lisboa'}
      </text>
    </g>

    {/* Concelho polygons — clickable navigation. Drawn on top of the
        precise land with transparent fill + faint strokes for the
        internal admin borders. */}
    <g class="concelhos">
      {geoData.concelhos.map((c) => {
        const isCurrent = c.slug === concelhoSlug;
        return (
          <a href={`${baseHref}/${c.slug}/`} class={`concelho-link ${isCurrent ? 'is-current' : ''}`} data-concelho-slug={c.slug}>
            <title>{c.name}{isStandard ? ` — ${c.area_km2.toFixed(0)} km² · ${c.population_2021?.toLocaleString('pt-PT')} habitantes` : ''}</title>
            {c.paths.map((d) => (
              <path
                d={d}
                class={`concelho ${isCurrent ? 'is-current' : ''}`}
              />
            ))}
            {(c.labelPositions ?? [c.labelXY]).map(([lx, ly]) => (
              <text
                x={lx}
                y={ly}
                class={`concelho-label ${isCurrent ? 'is-current' : ''} ${isStandard ? 'is-standard' : ''}`}
                text-anchor="middle"
                dominant-baseline="middle"
              >
                {c.name}
              </text>
            ))}
          </a>
        );
      })}
    </g>

    {/* Tejo bridges — real OSM geometry. 25 de Abril is the deck-outline
        polygon (closed); Vasco da Gama is the route centerline (open
        polyline). Both rendered in brand rust with an italic label. */}
    <g class="bridges">
      {bridges.map((b) => (
        <g class="bridge">
          <path d={b.d} class={b.shape === 'polygon' ? 'bridge__deck-poly' : 'bridge__deck-line'} />
          {isStandard && (
            <text
              x={b.labelXY[0]}
              y={b.labelXY[1]}
              text-anchor="middle"
              dominant-baseline="middle"
              class="bridge__label"
            >
              {b.name}
            </text>
          )}
        </g>
      ))}
    </g>

    {/* Water labels — set in the negative space between the two coasts.
        Tejo positioned at lat/lng so it lands in actual water (between
        Almada and Lisbon), not on top of land. */}
    {isStandard && (
      <g class="map-water-labels">
        <text
          x={project(-9.105, 38.708)[0]}
          y={project(-9.105, 38.708)[1]}
          class="water-label water-label--major"
          text-anchor="middle"
        >
          {waterLabels.tejo}
        </text>
        <text x={vbW * 0.04} y={vbH * 0.55} class="water-label" transform={`rotate(-90 ${vbW * 0.04} ${vbH * 0.55})`}>
          {waterLabels.atlantic}
        </text>
        <text x={vbW * 0.55} y={vbH * 0.96} class="water-label">
          {waterLabels.sado}
        </text>
      </g>
    )}

    {/* Place dot — drawn last so it sits on top */}
    {placeXY && (
      <g class="place-marker">
        <circle
          cx={placeXY[0]}
          cy={placeXY[1]}
          r="14"
          class="place-marker__halo"
        />
        <circle
          cx={placeXY[0]}
          cy={placeXY[1]}
          r="6"
          class="place-marker__dot"
        />
        <circle
          cx={placeXY[0]}
          cy={placeXY[1]}
          r="2.5"
          class="place-marker__core"
        />
      </g>
    )}
  </svg>

  {placeName && (
    <figcaption class="margem-map__caption smallcaps">
      {placeName} · Margem Sul
    </figcaption>
  )}

  {/* Mobile tap callout. Hidden by default, populated + shown by the
      tap-twice script on touch devices. First tap on a concelho fills
      this in with its name and a "tap again to open" hint; second tap
      navigates. */}
  <div class="margem-map__popup" aria-live="polite" data-empty>
    <span class="margem-map__popup-name"></span>
    <span class="margem-map__popup-hint" data-pt="Tocar de novo para abrir →" data-en="Tap again to open →"></span>
  </div>
</figure>

<script>
  // Tap-to-reveal-name pattern on touch devices: first tap on a concelho
  // populates the popup with the concelho name + a "tap again" hint and
  // highlights the shape. Second tap navigates. On a different concelho
  // the selection moves and you still need a second tap. Desktop
  // (hover capable) keeps single-click navigation.
  (() => {
    if (typeof window === 'undefined') return;
    const touch = window.matchMedia('(hover: none)').matches;
    if (!touch) return;
    const lang = document.documentElement.lang?.startsWith('en') ? 'en' : 'pt';

    document.querySelectorAll('.margem-map').forEach((map) => {
      const links = map.querySelectorAll('.concelho-link');
      const popup = map.querySelector('.margem-map__popup');
      const popupName = popup?.querySelector('.margem-map__popup-name');
      const popupHint = popup?.querySelector('.margem-map__popup-hint');
      if (!popup || !popupName || !popupHint) return;

      const clearTapped = () => {
        links.forEach((l) => l.classList.remove('is-tapped'));
        popup.setAttribute('data-empty', '');
        popupName.textContent = '';
      };

      links.forEach((link) => {
        link.addEventListener('click', (event) => {
          if (link.classList.contains('is-tapped') || link.classList.contains('is-current')) {
            return; // second tap (or tap on current) — let navigation through
          }
          event.preventDefault();
          links.forEach((l) => l.classList.remove('is-tapped'));
          link.classList.add('is-tapped');
          // The concelho's name is in its <title> child.
          const title = link.querySelector('title');
          popupName.textContent = title ? title.textContent : '';
          popupHint.textContent = popupHint.dataset[lang] || popupHint.dataset.pt || '';
          popup.removeAttribute('data-empty');
        });
      });

      // Tap outside any concelho clears the highlight + popup.
      map.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest('.concelho-link')) return;
        clearTapped();
      });
    });
  })();

  // List ↔ map hover sync. Any element with [data-concelho-link] on the
  // same page lights up the matching concelho on every MargemMap instance
  // when hovered/focused. Used by the /lugares list to mirror the map.
  (() => {
    if (typeof window === 'undefined') return;
    const apply = (slug, on) => {
      document.querySelectorAll(`.margem-map .concelho-link[data-concelho-slug="${slug}"]`).forEach((el) => {
        el.classList.toggle('is-listhover', on);
      });
    };
    document.querySelectorAll('[data-concelho-link]').forEach((item) => {
      const slug = item.getAttribute('data-concelho-link');
      if (!slug) return;
      item.addEventListener('mouseenter', () => apply(slug, true));
      item.addEventListener('mouseleave', () => apply(slug, false));
      item.addEventListener('focus', () => apply(slug, true));
      item.addEventListener('blur', () => apply(slug, false));
    });
  })();
</script>

<style>
  .margem-map {
    margin: 0;
    padding: 0;
    position: relative;
  }
  .margem-map__popup {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 10px 18px;
    background: var(--color-background);
    border: 1.5px solid var(--color-accent);
    border-radius: 999px;
    box-shadow: 0 6px 20px -8px color-mix(in srgb, var(--color-accent) 70%, transparent);
    pointer-events: none;
    z-index: 5;
    transition: opacity 160ms ease, transform 200ms ease;
    opacity: 1;
    max-width: 90%;
    text-align: center;
    white-space: nowrap;
  }
  .margem-map__popup[data-empty] {
    opacity: 0;
    transform: translateX(-50%) translateY(-6px);
  }
  .margem-map__popup-name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-accent);
    line-height: 1.1;
  }
  .margem-map__popup-hint {
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: var(--tracking-smallcaps);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    line-height: 1.1;
  }
  @media (hover: hover) {
    /* Desktop never shows the popup — hover does the work. */
    .margem-map__popup { display: none; }
  }
  .margem-map--mini {
    max-width: 360px;
  }
  .margem-map--standard {
    max-width: 720px;
    margin: 0 auto;
  }
  .margem-map svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ──────── Water base + land base + concelho borders ──────── */
  /* The water base is a faint teal wash. The Margem Sul land base is a
     single unioned shape drawn over the water so the land reads continuously.
     Individual concelhos are then drawn on top as fill: none — only their
     borders show, no per-concelho seam can leak teal through. */
  .water-base {
    fill: color-mix(in srgb, var(--mc-teal) 32%, var(--color-background));
  }
  .land-base {
    fill: var(--color-background);
    stroke: color-mix(in srgb, var(--mc-teal) 75%, var(--color-text));
    stroke-width: 0.6;
    stroke-linejoin: round;
    stroke-opacity: 0.7;
  }
  .margem-map--standard .land-base {
    stroke-width: 0.8;
    stroke-opacity: 0.85;
  }
  .concelho {
    fill: transparent;
    stroke: var(--color-text);
    stroke-opacity: 0.25;
    stroke-width: 0.8;
    stroke-linejoin: round;
    transition: fill 200ms ease, stroke-opacity 200ms ease;
  }
  .concelho-link {
    cursor: pointer;
    outline: none;
  }
  .concelho-link:hover .concelho,
  .concelho-link:focus-visible .concelho,
  .concelho-link.is-tapped .concelho,
  .concelho-link.is-listhover .concelho {
    fill: color-mix(in srgb, var(--color-accent) 22%, var(--color-background));
    stroke-opacity: 0.7;
  }
  .concelho.is-current {
    fill: color-mix(in srgb, var(--color-accent) 32%, var(--color-background));
    stroke: var(--color-accent);
    stroke-opacity: 0.8;
    stroke-width: 1.4;
  }
  .concelho-link.is-current:hover .concelho,
  .concelho-link.is-current.is-tapped .concelho {
    fill: color-mix(in srgb, var(--color-accent) 40%, var(--color-background));
  }

  /* ──────── Concelho labels ──────── */
  /* Permanently visible — hovering only changes the polygon fill, not
     the label visibility. paint-order: stroke gives a cream halo around
     each label so it reads cleanly on any background. */
  .concelho-label {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    fill: var(--color-text);
    fill-opacity: 0.85;
    pointer-events: none;
    paint-order: stroke;
    stroke: var(--color-background);
    stroke-width: 3px;
    stroke-linejoin: round;
    transition: fill 200ms ease, fill-opacity 200ms ease;
  }
  .concelho-link:hover .concelho-label,
  .concelho-link:focus-visible .concelho-label,
  .concelho-link.is-tapped .concelho-label,
  .concelho-link.is-listhover .concelho-label {
    fill: var(--color-accent);
    fill-opacity: 1;
  }
  .concelho-label.is-current {
    fill: var(--color-accent);
    font-size: 13px;
    font-weight: 600;
  }
  .margem-map--standard .concelho-label {
    font-size: 12px;
  }
  .margem-map--standard .concelho-label.is-current {
    font-size: 14px;
  }

  .context-label {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    fill: var(--color-text);
    fill-opacity: 0.55;
    pointer-events: none;
  }
  .margem-map--standard .context-label {
    font-size: 13px;
    fill-opacity: 0.7;
  }

  /* ──────── Bridges ──────── */
  /* 25 de Abril — closed deck outline as a filled polygon. */
  .bridge__deck-poly {
    fill: var(--color-accent);
    stroke: var(--color-accent);
    stroke-width: 0.5;
    stroke-linejoin: round;
  }
  /* Vasco da Gama — full route centerline as a stroked polyline. */
  .bridge__deck-line {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .margem-map--standard .bridge__deck-line {
    stroke-width: 2.4;
  }
  .bridge__label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 10px;
    letter-spacing: 0.08em;
    fill: var(--color-accent);
    fill-opacity: 0.9;
    paint-order: stroke;
    stroke: var(--color-background);
    stroke-width: 3;
    stroke-linejoin: round;
    pointer-events: none;
  }

  /* ──────── Water labels ──────── */
  .water-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    letter-spacing: 0.08em;
    fill: var(--color-accent);
    fill-opacity: 0.55;
    pointer-events: none;
  }
  .water-label--major {
    font-size: 28px;
    fill-opacity: 0.65;
  }
  .anchor-label {
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    fill: var(--color-text);
    fill-opacity: 0.4;
    pointer-events: none;
  }

  /* ──────── Place marker ──────── */
  .place-marker__halo {
    fill: var(--color-accent);
    fill-opacity: 0.12;
    animation: place-pulse 2.8s ease-in-out infinite;
  }
  .place-marker__dot {
    fill: var(--color-accent);
    stroke: var(--color-background);
    stroke-width: 2;
  }
  .place-marker__core {
    fill: var(--color-background);
  }
  @keyframes place-pulse {
    0%, 100% { transform: scale(1); opacity: 0.55; transform-origin: center; transform-box: fill-box; }
    50% { transform: scale(1.35); opacity: 0.18; transform-origin: center; transform-box: fill-box; }
  }
  @media (prefers-reduced-motion: reduce) {
    .place-marker__halo { animation: none; }
  }

  /* ──────── Caption ──────── */
  .margem-map__caption {
    display: block;
    margin: var(--space-xs) 0 0;
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
  }
</style>
