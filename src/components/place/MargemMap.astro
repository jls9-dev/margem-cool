---
/**
 * MargemMap — interactive Leaflet map of the Margem Sul's 9 concelhos.
 *
 * Real OSM tiles via Leaflet + CARTO light, with the 9 concelhos
 * overlaid as clickable polygons in brand rust and the unified Margem
 * Sul perimeter outlined in brand teal so the whole region reads as
 * one thing at a glance. No projection maths, no hand-traced geometry,
 * no bridge control points — the bridges, coastlines and salinas all
 * come from OSM tiles.
 *
 * Pattern from southbank.pt/area-guides, adapted from pins to polygons
 * because Margem Cool's regions are large administrative areas where
 * users expect "click the region" rather than "click the dot".
 *
 * Data:
 *   - src/data/geo/concelhos-latlng.json (9 concelho features)
 *   - src/data/geo/margem-sul-outline.json (unioned perimeter)
 *   Regenerate via scripts/build-concelhos-leaflet.mjs.
 *
 * Cross-project rule: feedback_real_map_not_handdrawn.md.
 */
import concelhosFC from '../../data/geo/concelhos-latlng.json';
import outlineFC from '../../data/geo/margem-sul-outline.json';

interface Props {
  size?: 'mini' | 'standard';
  concelhoSlug?: string;     // Highlighted concelho (place's parent)
  placeName?: string;        // For caption + place-marker tooltip
  placeCentroid?: [number, number];  // [lng, lat] from frontmatter geo.centroid
  lang?: 'pt' | 'en';        // For link URL prefix
}

const {
  size = 'mini',
  concelhoSlug,
  placeName,
  placeCentroid,
  lang = 'pt',
} = Astro.props;

const baseHref = lang === 'en' ? '/en/places' : '/lugares';

// Label anchor (lat, lng) per concelho — hand-tuned to spread the four
// Tejo-bank towns (Almada / Seixal / Barreiro / Moita) so the labels
// don't dogpile at the default zoom, and to land each name on its own
// concelho's land mass rather than the geometric centroid (which for
// irregular concelhos drifts to salt flats or exclaves).
const labelAnchors: Record<string, [number, number]> = {
  almada:    [38.6450, -9.2050],  // Costa da Caparica — well clear of the cluster
  seixal:    [38.6050, -9.1100],  // mid-Seixal, south of Amora
  sesimbra:  [38.4900, -9.1100],  // pulled up to mid-Sesimbra (concelho extends to ~38.55)
  setubal:   [38.5300, -8.8800],
  palmela:   [38.6050, -8.7700],  // east-central Palmela, well clear of Setúbal
  barreiro:  [38.6350, -9.0700],  // pulled south into southern Barreiro / Coina side
  moita:     [38.6600, -8.9700],  // pulled up towards the Tejo-bank top of Moita
  montijo:   [38.7050, -8.9550],
  alcochete: [38.7550, -8.9400],
};

const mapData = {
  baseHref,
  currentSlug: concelhoSlug ?? null,
  concelhos: concelhosFC,
  outline: outlineFC,
  labelAnchors,
  place: placeCentroid && placeName
    ? { name: placeName, lat: placeCentroid[1], lng: placeCentroid[0] }
    : null,
};

const tapAgainHint = lang === 'en' ? 'Tap again to open' : 'Tocar de novo para abrir';
---

<figure class={`margem-map margem-map--${size}`} aria-label={`Mapa da Margem Sul${placeName ? ` — ${placeName}` : ''}`}>
  <div class="margem-map__canvas" data-margem-map>
    <noscript>
      <p class="margem-map__noscript">
        {lang === 'en'
          ? 'Enable JavaScript to view the interactive map of the 9 Margem Sul concelhos.'
          : 'Ative o JavaScript para ver o mapa interativo dos 9 concelhos da Margem Sul.'}
      </p>
    </noscript>
  </div>
  <script type="application/json" data-margem-map-config set:html={JSON.stringify(mapData)}></script>

  {placeName && (
    <figcaption class="margem-map__caption smallcaps">
      {placeName} · Margem Sul
    </figcaption>
  )}
</figure>

<script is:inline define:vars={{ tapAgainHint }}>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.__margemMapInit) {
      window.__margemMapInit();
      return;
    }

    var LEAFLET_CSS = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css';
    var LEAFLET_JS = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js';
    // light_nolabels — same CARTO light tiles but without the
    // built-in place labels (Lisbon, Setúbal, Sesimbra etc.). We layer
    // our own concelho labels on top with brand typography; the OSM
    // tile's labels would duplicate ours.
    var TILE_URL = 'https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png';
    var TILE_ATTRIB = '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/attributions">CARTO</a>';
    var MOBILE_QUERY = '(max-width: 900px)';

    function ensureLeaflet(cb) {
      if (typeof L !== 'undefined') { cb(); return; }
      if (!document.querySelector('link[data-leaflet-css]')) {
        var css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = LEAFLET_CSS;
        css.setAttribute('data-leaflet-css', '');
        document.head.appendChild(css);
      }
      var existing = document.querySelector('script[data-leaflet-js]');
      if (existing) {
        existing.addEventListener('load', cb);
        return;
      }
      var js = document.createElement('script');
      js.src = LEAFLET_JS;
      js.async = true;
      js.setAttribute('data-leaflet-js', '');
      js.onload = cb;
      js.onerror = function () {
        document.querySelectorAll('[data-margem-map]').forEach(function (el) {
          el.innerHTML = '<div class="margem-map__error">Failed to load map. Refresh the page.</div>';
        });
      };
      document.head.appendChild(js);
    }

    function initOne(canvas) {
      if (canvas.__margemMapReady) return;
      canvas.__margemMapReady = true;

      var cfgEl = canvas.parentElement.querySelector('script[data-margem-map-config]');
      if (!cfgEl) return;
      var cfg = JSON.parse(cfgEl.textContent || '{}');

      var map = L.map(canvas, {
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: true,
      });

      L.tileLayer(TILE_URL, {
        attribution: TILE_ATTRIB,
        subdomains: 'abcd',
        maxZoom: 18,
      }).addTo(map);

      // ── Margem Sul perimeter ───────────────────────────────────
      // Confident 2.5px teal line, no halo, no fill. Designed maps
      // don't need haloed outlines; the teal sits clearly over the
      // CARTO light tiles. Drawn first so the concelho polygons can
      // be brought to front on hover without sliding under the
      // perimeter.
      var outlineLayer = L.geoJSON(cfg.outline, {
        style: {
          color: '#2C6B73',
          weight: 2.5,
          opacity: 0.85,
          fill: false,
          lineJoin: 'round',
          lineCap: 'round',
        },
        interactive: false,
      }).addTo(map);

      // ── Concelho polygons ───────────────────────────────────────
      // Default state: no fill, just a thin rust border so the OSM
      // tiles read clearly through the regions. Hover wakes them up
      // with a clear rust fill. Current concelho is unmistakeable.
      var openSlug = null;

      // Always keep fill: true so setStyle only has to toggle
      // fillOpacity. Toggling fill: true/false via setStyle leaves the
      // hover updates inconsistent because Leaflet doesn't re-create
      // the underlying SVG fill attribute.
      function baseStyle(slug) {
        var isCurrent = slug === cfg.currentSlug;
        return isCurrent
          ? { color: '#B7472A', weight: 2.5, opacity: 1.0,  fillColor: '#B7472A', fillOpacity: 0.30, fill: true }
          : { color: '#B7472A', weight: 1.2, opacity: 0.55, fillColor: '#B7472A', fillOpacity: 0,    fill: true };
      }
      function hoverStyle() {
        return { color: '#B7472A', weight: 2.2, opacity: 0.95, fillColor: '#B7472A', fillOpacity: 0.24, fill: true };
      }

      L.geoJSON(cfg.concelhos, {
        style: function (feature) { return baseStyle(feature.properties.slug); },
        onEachFeature: function (feature, layer) {
          var slug = feature.properties.slug;
          var name = feature.properties.name;
          var href = cfg.baseHref + '/' + slug + '/';

          // Hover. Don't bringToFront — that causes Leaflet to reorder
          // the SVG and the previous concelho's mouseout fires too
          // late, leaving polygons stuck looking highlighted.
          layer.on('mouseover', function () {
            if (slug !== cfg.currentSlug) layer.setStyle(hoverStyle());
          });
          layer.on('mouseout', function () {
            if (slug !== cfg.currentSlug) layer.setStyle(baseStyle(slug));
          });
          layer.on('click', function (e) {
            L.DomEvent.stopPropagation(e);
            var isMobile = window.matchMedia(MOBILE_QUERY).matches;
            if (!isMobile) {
              window.location.href = href;
              return;
            }
            if (openSlug === slug) {
              window.location.href = href;
              return;
            }
            openSlug = slug;
            var html = '<a href="' + href + '" class="mc-pin-popup-link">' +
              name + '<span class="mc-pin-popup-hint">' + tapAgainHint + ' &rarr;</span></a>';
            L.popup({
              closeButton: false,
              className: 'mc-pin-popup',
              autoClose: true,
              closeOnClick: true,
              offset: [0, -4],
            }).setLatLng(e.latlng).setContent(html).openOn(map);
          });
        },
      }).addTo(map);

      // ── Concelho labels ────────────────────────────────────────
      // 1px divIcon so the label width is determined entirely by CSS
      // (transform: translate(-50%, -50%) on the inner span keeps it
      // centred on the anchor point). interactive:false plus CSS
      // pointer-events:none on every descendant so the labels never
      // intercept polygon hover/click events.
      Object.keys(cfg.labelAnchors).forEach(function (slug) {
        var anchor = cfg.labelAnchors[slug];
        var feat = cfg.concelhos.features.find(function (f) { return f.properties.slug === slug; });
        if (!feat) return;
        var labelIcon = L.divIcon({
          className: 'mc-concelho-label' + (slug === cfg.currentSlug ? ' mc-concelho-label--current' : ''),
          html: '<span>' + feat.properties.name + '</span>',
          iconSize: [1, 1],
          iconAnchor: [0, 0],
        });
        L.marker(anchor, { icon: labelIcon, interactive: false, keyboard: false })
          .addTo(map);
      });

      // ── Place marker (freguesia / bairro pages) ────────────────
      if (cfg.place) {
        var placeIcon = L.divIcon({
          className: 'mc-place-pin',
          html: '<div class="mc-place-pin__halo"></div><div class="mc-place-pin__dot"></div>',
          iconSize: [28, 28],
          iconAnchor: [14, 14],
        });
        L.marker([cfg.place.lat, cfg.place.lng], { icon: placeIcon, interactive: false })
          .bindTooltip(cfg.place.name, {
            permanent: true,
            direction: 'top',
            offset: [0, -10],
            className: 'mc-place-tooltip',
          })
          .addTo(map);
      }

      map.on('popupclose', function () { openSlug = null; });

      // Fit to the outline bounds (the perimeter, not individual
      // concelhos) so the whole region is framed consistently.
      var bounds = outlineLayer.getBounds();
      if (cfg.place) bounds.extend([cfg.place.lat, cfg.place.lng]);
      map.fitBounds(bounds, { padding: [24, 24] });
    }

    function initAll() {
      document.querySelectorAll('[data-margem-map]').forEach(initOne);
    }

    window.__margemMapInit = function () {
      ensureLeaflet(initAll);
    };
    window.__margemMapInit();
  })();
</script>

<style is:global>
  /* ── Map container ── */
  .margem-map {
    margin: 0;
    padding: 0;
  }
  .margem-map--mini .margem-map__canvas {
    height: 360px;
  }
  .margem-map--standard .margem-map__canvas {
    height: 540px;
  }
  @media (max-width: 600px) {
    .margem-map--standard .margem-map__canvas {
      height: 420px;
    }
  }
  .margem-map__canvas {
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    background: color-mix(in srgb, var(--mc-teal) 10%, var(--color-background));
  }
  .margem-map__noscript,
  .margem-map__error {
    padding: 40px;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 15px;
  }

  /* ── Leaflet overrides — brand chrome ── */
  .leaflet-control-attribution {
    font-size: 9px !important;
    background: color-mix(in srgb, var(--color-background) 88%, transparent) !important;
  }
  .leaflet-control-zoom a {
    background: var(--color-background) !important;
    color: var(--color-accent) !important;
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent) !important;
    font-weight: 700 !important;
  }
  .leaflet-control-zoom a:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-background)) !important;
    color: var(--color-accent) !important;
  }
  .leaflet-container {
    font-family: var(--font-body) !important;
    background: color-mix(in srgb, var(--mc-teal) 10%, var(--color-background)) !important;
  }

  /* ── Concelho labels (permanent, on-map) ──
     Each label is a 1×1px divIcon; the inner span is centred on the
     anchor with translate(-50%, -50%) so its visual width is its
     content width, not the icon box. pointer-events:none on every
     descendant so the labels never block polygon hover/click. */
  .mc-concelho-label,
  .mc-concelho-label * {
    pointer-events: none !important;
  }
  .mc-concelho-label {
    background: transparent !important;
    border: 0 !important;
  }
  .mc-concelho-label span {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text);
    white-space: nowrap;
    /* Cream halo via stacked text-shadow — gives the label a confident
       breath of cream so the type reads cleanly without a boxy
       backdrop. Stacked so the halo is thick enough at 12px. */
    text-shadow:
      0 0 4px var(--color-background),
      0 0 4px var(--color-background),
      0 0 8px var(--color-background),
      0 0 8px var(--color-background),
      0 1px 0 var(--color-background);
  }
  .mc-concelho-label--current span {
    color: var(--color-accent);
    font-size: 13px;
    letter-spacing: 0.24em;
  }

  /* ── Mobile popup (tap-twice on a concelho polygon) ── */
  .mc-pin-popup .leaflet-popup-content-wrapper {
    background: var(--color-background) !important;
    padding: 0 !important;
    border-radius: 4px !important;
    border: 1.5px solid var(--color-accent) !important;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--color-accent) 30%, transparent) !important;
  }
  .mc-pin-popup .leaflet-popup-content {
    margin: 0 !important;
    line-height: 1.1 !important;
  }
  .mc-pin-popup .leaflet-popup-tip {
    background: var(--color-background) !important;
    border: 1.5px solid var(--color-accent) !important;
  }
  .mc-pin-popup-link {
    display: flex !important;
    flex-direction: column;
    align-items: flex-start;
    padding: 10px 16px !important;
    font-family: var(--font-display) !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    color: var(--color-accent) !important;
    text-decoration: none !important;
    white-space: nowrap;
  }
  .mc-pin-popup-hint {
    display: block;
    font-size: 10px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
    text-transform: uppercase;
    margin-top: 3px;
  }

  /* ── Place marker (freguesia/bairro pin on its overview page) ── */
  .mc-place-pin {
    pointer-events: none;
  }
  .mc-place-pin__halo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    opacity: 0.20;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: mc-place-pulse 2.6s ease-in-out infinite;
  }
  .mc-place-pin__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 14px;
    height: 14px;
    background: var(--color-accent);
    border: 3px solid var(--color-background);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 2px 6px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }
  @keyframes mc-place-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);   opacity: 0.30; }
    50%      { transform: translate(-50%, -50%) scale(1.7); opacity: 0.05; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mc-place-pin__halo { animation: none; }
  }
  .mc-place-tooltip {
    background: var(--color-accent) !important;
    color: var(--color-background) !important;
    font-family: var(--font-display) !important;
    font-size: 11px !important;
    letter-spacing: var(--tracking-smallcaps);
    text-transform: uppercase;
    font-weight: 600 !important;
    padding: 4px 10px !important;
    border: none !important;
    border-radius: 4px !important;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 30%, transparent) !important;
  }
  .mc-place-tooltip.leaflet-tooltip-top:before {
    border-top-color: var(--color-accent) !important;
  }

  /* ── Caption ── */
  .margem-map__caption {
    display: block;
    margin: var(--space-xs) 0 0;
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
  }
</style>
