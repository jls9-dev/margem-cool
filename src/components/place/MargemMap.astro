---
/**
 * MargemMap — interactive Leaflet map of the Margem Sul's 9 concelhos.
 *
 * Built the same way southbank.pt/area-guides does it: Leaflet + CARTO
 * light tiles + one marker per region. No hand-drawn SVG, no projection
 * maths, no GeoJSON path tracing — bridges, coastlines, salinas all
 * come from real OSM tiles. The brand colours apply to the markers and
 * the chrome around the map; the geography is OSM's.
 *
 * Props are unchanged from the previous SVG implementation so this is
 * a drop-in replacement.
 *
 * Sizes:
 *   - 'mini' — hero slot use; 360px tall, fits in cards
 *   - 'standard' — feature use on concelho pages and homepage; 540px tall
 *
 * Pattern reference: ~/southbank-pt/src/pages/area-guides/index.astro.
 * Cross-project rule: feedback_real_map_not_handdrawn.md.
 */

interface Props {
  size?: 'mini' | 'standard';
  concelhoSlug?: string;     // Highlighted concelho (place's parent)
  placeName?: string;        // For caption + place-marker tooltip
  placeCentroid?: [number, number];  // [lng, lat] from frontmatter geo.centroid
  lang?: 'pt' | 'en';        // For link URL prefix
}

const {
  size = 'mini',
  concelhoSlug,
  placeName,
  placeCentroid,
  lang = 'pt',
} = Astro.props;

const baseHref = lang === 'en' ? '/en/places' : '/lugares';

// Town-centre lat/lng per concelho — anchors the marker where users
// associate the concelho name (Almada town, not Almada's geometric
// centroid which sits west of Costa da Caparica; Montijo town in the
// western piece, not the eastern exclave centroid).
const concelhos = [
  { slug: 'almada',    name: 'Almada',    lat: 38.6788, lng: -9.1571 },
  { slug: 'seixal',    name: 'Seixal',    lat: 38.6444, lng: -9.1042 },
  { slug: 'sesimbra',  name: 'Sesimbra',  lat: 38.4458, lng: -9.1014 },
  { slug: 'setubal',   name: 'Setúbal',   lat: 38.5244, lng: -8.8944 },
  { slug: 'palmela',   name: 'Palmela',   lat: 38.5694, lng: -8.9028 },
  { slug: 'barreiro',  name: 'Barreiro',  lat: 38.6594, lng: -9.0744 },
  { slug: 'moita',     name: 'Moita',     lat: 38.6500, lng: -8.9900 },
  { slug: 'montijo',   name: 'Montijo',   lat: 38.7100, lng: -8.9700 },
  { slug: 'alcochete', name: 'Alcochete', lat: 38.7556, lng: -8.9667 },
];

// Serialise the data the inline init script needs. Avoids the script
// having to import anything at runtime.
const mapData = {
  baseHref,
  currentSlug: concelhoSlug ?? null,
  concelhos,
  place: placeCentroid && placeName
    ? { name: placeName, lat: placeCentroid[1], lng: placeCentroid[0] }
    : null,
};

const tapAgainHint = lang === 'en' ? 'Tap again to open' : 'Tocar de novo para abrir';
---

<figure class={`margem-map margem-map--${size}`} aria-label={`Mapa da Margem Sul${placeName ? ` — ${placeName}` : ''}`}>
  <div class="margem-map__canvas" data-margem-map>
    <noscript>
      <p class="margem-map__noscript">
        {lang === 'en'
          ? 'Enable JavaScript to view the interactive map of the 9 Margem Sul concelhos.'
          : 'Ative o JavaScript para ver o mapa interativo dos 9 concelhos da Margem Sul.'}
      </p>
    </noscript>
  </div>
  <script type="application/json" data-margem-map-config set:html={JSON.stringify(mapData)}></script>

  {placeName && (
    <figcaption class="margem-map__caption smallcaps">
      {placeName} · Margem Sul
    </figcaption>
  )}
</figure>

<script is:inline define:vars={{ tapAgainHint }}>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.__margemMapInit) {
      window.__margemMapInit();
      return;
    }

    var LEAFLET_CSS = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css';
    var LEAFLET_JS = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js';
    var TILE_URL = 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png';
    var TILE_ATTRIB = '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/attributions">CARTO</a>';
    var MOBILE_QUERY = '(max-width: 900px)';

    function ensureLeaflet(cb) {
      if (typeof L !== 'undefined') { cb(); return; }
      if (!document.querySelector('link[data-leaflet-css]')) {
        var css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = LEAFLET_CSS;
        css.setAttribute('data-leaflet-css', '');
        document.head.appendChild(css);
      }
      var existing = document.querySelector('script[data-leaflet-js]');
      if (existing) {
        existing.addEventListener('load', cb);
        return;
      }
      var js = document.createElement('script');
      js.src = LEAFLET_JS;
      js.async = true;
      js.setAttribute('data-leaflet-js', '');
      js.onload = cb;
      js.onerror = function () {
        document.querySelectorAll('[data-margem-map]').forEach(function (el) {
          el.innerHTML = '<div class="margem-map__error">Failed to load map. Refresh the page.</div>';
        });
      };
      document.head.appendChild(js);
    }

    function initOne(canvas) {
      if (canvas.__margemMapReady) return;
      canvas.__margemMapReady = true;

      var cfgEl = canvas.parentElement.querySelector('script[data-margem-map-config]');
      if (!cfgEl) return;
      var cfg = JSON.parse(cfgEl.textContent || '{}');

      var map = L.map(canvas, {
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: true,
      });

      L.tileLayer(TILE_URL, {
        attribution: TILE_ATTRIB,
        subdomains: 'abcd',
        maxZoom: 18,
      }).addTo(map);

      var sharedPopup = null;
      var openMarker = null;
      var markers = [];

      function makeIcon(slug) {
        var isCurrent = slug === cfg.currentSlug;
        return L.divIcon({
          className: 'mc-area-pin' + (isCurrent ? ' mc-area-pin--current' : ''),
          html: '<div class="mc-pin-circle"></div>',
          iconSize: [24, 24],
          iconAnchor: [12, 12],
        });
      }

      cfg.concelhos.forEach(function (c) {
        var marker = L.marker([c.lat, c.lng], { icon: makeIcon(c.slug) })
          .bindTooltip(c.name, {
            permanent: false,
            direction: 'top',
            offset: [0, -8],
            className: 'mc-pin-tooltip',
          })
          .addTo(map);

        marker.on('click', function (e) {
          L.DomEvent.stopPropagation(e);
          var isMobile = window.matchMedia(MOBILE_QUERY).matches;
          var href = cfg.baseHref + '/' + c.slug + '/';
          if (!isMobile) {
            window.location.href = href;
            return;
          }
          marker.closeTooltip();
          if (openMarker === marker) {
            window.location.href = href;
            return;
          }
          var html = '<a href="' + href + '" class="mc-pin-popup-link">' +
            c.name + ' <span class="mc-pin-popup-hint">' + tapAgainHint + ' &rarr;</span></a>';
          if (!sharedPopup) {
            sharedPopup = L.popup({
              closeButton: false,
              offset: [0, -8],
              className: 'mc-pin-popup',
              autoClose: true,
              closeOnClick: true,
            });
          }
          sharedPopup.setLatLng(marker.getLatLng()).setContent(html).openOn(map);
          openMarker = marker;
        });

        markers.push(marker);
      });

      map.on('popupclose', function (e) {
        if (e.popup === sharedPopup) openMarker = null;
      });

      // Place marker (freguesia/bairro page) — distinct visual, no link.
      if (cfg.place) {
        var placeIcon = L.divIcon({
          className: 'mc-place-pin',
          html: '<div class="mc-place-pin__halo"></div><div class="mc-place-pin__dot"></div>',
          iconSize: [28, 28],
          iconAnchor: [14, 14],
        });
        L.marker([cfg.place.lat, cfg.place.lng], { icon: placeIcon, interactive: false })
          .bindTooltip(cfg.place.name, {
            permanent: true,
            direction: 'top',
            offset: [0, -10],
            className: 'mc-place-tooltip',
          })
          .addTo(map);
      }

      // Fit bounds. Include the place marker if present so it's not
      // off-frame.
      var bounds = L.featureGroup(markers).getBounds();
      if (cfg.place) bounds.extend([cfg.place.lat, cfg.place.lng]);
      map.fitBounds(bounds, { padding: [28, 28] });
    }

    function initAll() {
      document.querySelectorAll('[data-margem-map]').forEach(initOne);
    }

    window.__margemMapInit = function () {
      ensureLeaflet(initAll);
    };
    window.__margemMapInit();
  })();
</script>

<style is:global>
  /* ── Map container ── */
  .margem-map {
    margin: 0;
    padding: 0;
  }
  .margem-map--mini .margem-map__canvas {
    height: 360px;
  }
  .margem-map--standard .margem-map__canvas {
    height: 540px;
  }
  @media (max-width: 600px) {
    .margem-map--standard .margem-map__canvas {
      height: 420px;
    }
  }
  .margem-map__canvas {
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    background: color-mix(in srgb, var(--mc-teal) 12%, var(--color-background));
  }
  .margem-map__noscript,
  .margem-map__error {
    padding: 40px;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 15px;
  }

  /* ── Leaflet overrides — brand chrome ── */
  .leaflet-control-attribution {
    font-size: 9px !important;
    background: color-mix(in srgb, var(--color-background) 88%, transparent) !important;
  }
  .leaflet-control-zoom a {
    background: var(--color-background) !important;
    color: var(--color-accent) !important;
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent) !important;
    font-weight: 700 !important;
  }
  .leaflet-control-zoom a:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-background)) !important;
    color: var(--color-accent) !important;
  }
  .leaflet-container {
    font-family: var(--font-body) !important;
    background: color-mix(in srgb, var(--mc-teal) 12%, var(--color-background)) !important;
  }

  /* ── Concelho pin ── */
  .mc-area-pin {
    display: flex !important;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .mc-pin-circle {
    width: 18px;
    height: 18px;
    background: var(--color-accent);
    border: 3px solid var(--color-background);
    border-radius: 50%;
    box-shadow: 0 2px 6px color-mix(in srgb, var(--color-accent) 38%, transparent);
    position: relative;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .mc-pin-circle::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--color-background);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .mc-area-pin:hover .mc-pin-circle {
    transform: scale(1.3);
    z-index: 1000;
  }
  .mc-area-pin--current .mc-pin-circle {
    transform: scale(1.4);
    background: var(--mc-teal, var(--color-accent));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 22%, transparent),
                0 3px 10px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  /* ── Tooltip (hover label) ── */
  .mc-pin-tooltip {
    background: var(--color-background) !important;
    color: var(--color-text) !important;
    font-family: var(--font-display) !important;
    font-size: 12px !important;
    letter-spacing: var(--tracking-smallcaps);
    text-transform: uppercase;
    font-weight: 600 !important;
    padding: 5px 12px !important;
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent) !important;
    border-radius: 4px !important;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 18%, transparent) !important;
    white-space: nowrap;
  }
  .mc-pin-tooltip.leaflet-tooltip-top:before {
    border-top-color: var(--color-background) !important;
  }

  /* ── Mobile popup (tap-twice) ── */
  .mc-pin-popup .leaflet-popup-content-wrapper {
    background: var(--color-background) !important;
    padding: 0 !important;
    border-radius: 4px !important;
    border: 1.5px solid var(--color-accent) !important;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--color-accent) 30%, transparent) !important;
  }
  .mc-pin-popup .leaflet-popup-content {
    margin: 0 !important;
    line-height: 1.1 !important;
  }
  .mc-pin-popup .leaflet-popup-tip {
    background: var(--color-background) !important;
  }
  .mc-pin-popup-link {
    display: flex !important;
    flex-direction: column;
    align-items: flex-start;
    padding: 10px 16px !important;
    font-family: var(--font-display) !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    color: var(--color-accent) !important;
    text-decoration: none !important;
    white-space: nowrap;
  }
  .mc-pin-popup-hint {
    font-size: 10px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* ── Place marker (freguesia/bairro pin on its overview page) ── */
  .mc-place-pin {
    pointer-events: none;
  }
  .mc-place-pin__halo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    opacity: 0.18;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: mc-place-pulse 2.6s ease-in-out infinite;
  }
  .mc-place-pin__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12px;
    height: 12px;
    background: var(--color-accent);
    border: 2px solid var(--color-background);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 2px 6px color-mix(in srgb, var(--color-accent) 50%, transparent);
  }
  @keyframes mc-place-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.28; }
    50%      { transform: translate(-50%, -50%) scale(1.6); opacity: 0.08; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mc-place-pin__halo { animation: none; }
  }
  .mc-place-tooltip {
    background: var(--color-accent) !important;
    color: var(--color-background) !important;
    font-family: var(--font-display) !important;
    font-size: 11px !important;
    letter-spacing: var(--tracking-smallcaps);
    text-transform: uppercase;
    font-weight: 600 !important;
    padding: 4px 10px !important;
    border: none !important;
    border-radius: 4px !important;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 30%, transparent) !important;
  }
  .mc-place-tooltip.leaflet-tooltip-top:before {
    border-top-color: var(--color-accent) !important;
  }

  /* ── Caption ── */
  .margem-map__caption {
    display: block;
    margin: var(--space-xs) 0 0;
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-smallcaps);
  }
</style>
