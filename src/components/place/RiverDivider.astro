---
/**
 * RiverDivider — the brand's river curve, scaled small, used as a section
 * separator. Path math matches the river curve in the wordmark exactly
 * (scripts/build-wordmark-svg.mjs):
 *
 *   M 0 0
 *   C 40 20, 95 -18, 150 15
 *   S 210 -6, 280 0
 *
 * Same gesture, same proportions, same stroke-to-width ratio. Just smaller.
 */
interface Props {
  width?: number;
  align?: 'left' | 'center';
}
const { width = 200, align = 'center' } = Astro.props;
const aspect = 50 / 290;
const height = Math.round(width * aspect);
---

<div class={`river-divider river-divider--${align}`} aria-hidden="true">
  <svg
    width={width}
    height={height}
    viewBox="-5 -25 290 50"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M 0 0 C 40 20, 95 -18, 150 15 S 210 -6, 280 0"
      fill="none"
      stroke="var(--color-accent)"
      stroke-width="13"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</div>

<style>
  .river-divider {
    display: flex;
    padding: var(--space-lg) 0;
  }
  .river-divider--center { justify-content: center; }
  .river-divider--left { justify-content: flex-start; }
</style>
