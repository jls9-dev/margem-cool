---
/**
 * BackLink — small "back to all places" link at the very bottom of a page.
 */
interface Props {
  href: string;
  label: string;
}
const { href, label } = Astro.props;
---

<div class="place-back">
  <div class="container">
    <a href={href} class="place-back__link smallcaps">{label}</a>
  </div>
</div>

<style>
  .place-back {
    padding: var(--space-lg) 0 var(--space-2xl);
  }
  .place-back__link {
    font-family: var(--font-display);
    font-size: var(--type-caption);
    color: var(--color-text-secondary);
    border-bottom: 0;
  }
  .place-back__link:hover {
    color: var(--color-accent);
  }
</style>
