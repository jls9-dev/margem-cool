---
/**
 * GuideHero — top of every place page.
 * Eyebrow (context line) + H1 + dek (short description) + updated date,
 * with an optional MiniMap slot positioned to the right on desktop and
 * stacked beneath on mobile.
 */
interface Props {
  kicker: string;
  title: string;
  dek: string;
  updatedLabel: string;
}
const { kicker, title, dek, updatedLabel } = Astro.props;
---

<header class="guide-hero">
  <div class="container">
    <div class="guide-hero__inner">
      <div class="guide-hero__text">
        <p class="guide-hero__kicker smallcaps">{kicker}</p>
        <h1 class="guide-hero__title">{title}</h1>
        <p class="guide-hero__dek">{dek}</p>
        <p class="guide-hero__updated smallcaps">{updatedLabel}</p>
      </div>
      <div class="guide-hero__map">
        <slot name="map" />
      </div>
    </div>
  </div>
</header>

<style>
  .guide-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }
  .guide-hero__inner {
    max-width: var(--wide-section);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 900px) {
    .guide-hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
  .guide-hero__text {
    max-width: var(--content-column);
  }
  .guide-hero__map {
    min-width: 240px;
  }
  @media (max-width: 900px) {
    .guide-hero__map { order: -1; }
  }

  .guide-hero__kicker {
    margin: 0 0 var(--space-md);
    color: var(--color-accent);
    font-size: var(--type-caption);
  }
  .guide-hero__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--type-h1);
    line-height: var(--leading-headline);
    margin: 0 0 var(--space-md);
    letter-spacing: -0.015em;
  }
  @media (max-width: 720px) {
    .guide-hero__title { font-size: var(--type-h1-mobile); }
  }
  .guide-hero__dek {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--type-lead);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-lg);
  }
  .guide-hero__updated {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-caption);
  }
</style>
