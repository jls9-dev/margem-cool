---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  lang="en"
  title="Analytics opt-out · Margem Cool"
  description="Exclude this browser from analytics on margemcool.pt."
  alternateUrl="/optout/"
  canonicalPath="/en/optout/"
  noindex={true}
>
  <main class="container container--narrow" style="padding: 4rem 0;">
    <h1 id="ok-title" style="display:none">You're excluded from analytics on margemcool.pt</h1>
    <h1 id="setting-title">Setting the staff exclusion cookie…</h1>
    <p id="setting-msg">
      Setting a cookie so Cloudflare Zaraz won't fire the analytics tag on your visits.
      Takes effect on the next page load.
    </p>
    <p id="ok-msg" style="display:none">
      Your visits to margemcool.pt from <strong>this browser on this device</strong>
      won't be counted in Cloudflare Web Analytics any more. The cookie lasts 2 years.
      Repeat the opt-out on each browser and device you use, and again if you ever
      clear cookies.
    </p>
    <p id="fail-msg" style="display:none">
      Your browser blocked the cookie (private mode, strict tracking-protection, etc.).
      Try a different browser, or use the same browser without private mode.
    </p>
    <p style="margin-top: 1.5rem;">
      <a href="/en/">← Back to the home page</a>
    </p>
  </main>
</BaseLayout>

<script is:inline>
  (function () {
    var twoYears = 60 * 60 * 24 * 365 * 2;
    document.cookie = 'spandera-staff=1; Path=/; Max-Age=' + twoYears + '; SameSite=Lax; Secure';
    var set = document.cookie.split(';').some(function (c) { return c.trim().indexOf('spandera-staff=1') === 0; });
    if (set) {
      document.getElementById('setting-title').style.display = 'none';
      document.getElementById('setting-msg').style.display = 'none';
      document.getElementById('ok-title').style.display = '';
      document.getElementById('ok-msg').style.display = '';
    } else {
      document.getElementById('setting-title').textContent = 'Could not set the cookie';
      document.getElementById('setting-msg').style.display = 'none';
      document.getElementById('fail-msg').style.display = '';
    }
  })();
</script>
