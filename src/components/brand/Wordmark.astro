---
/**
 * Wordmark — stacked "margem cool" mark with l descending into the river.
 *
 * Inlines the SVG file at build time via the `?raw` import suffix so the
 * embedded style block is treated as a normal stylesheet by the browser.
 * When SVGs are loaded via <img>, browsers run them in a restricted mode
 * that can skip class-based fills, which is why we don't load it as an
 * external image.
 */
import svgSource from '../../../public/wordmark-stacked.svg?raw';

interface Props {
  size?: number;
  ariaLabel?: string;
}
const { size = 360, ariaLabel = 'margem cool' } = Astro.props;

const sized = svgSource
  .replace('<svg ', `<svg width="${size}" `)
  .replace('aria-label="margem cool"', `aria-label="${ariaLabel}"`);
---

<Fragment set:html={sized} />
