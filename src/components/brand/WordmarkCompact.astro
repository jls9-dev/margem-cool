---
/**
 * WordmarkCompact — horizontal "margem cool" wordmark for headers and compact
 * spots. Loads the standalone paths-only SVG from /public/wordmark.svg so the
 * mark renders identically everywhere with no webfont dependency.
 */
interface Props {
  height?: number;
  ariaLabel?: string;
}
const { height = 36, ariaLabel = 'margem cool' } = Astro.props;
---

<img
  class="mc-wordmark-compact"
  src="/wordmark.svg"
  height={height}
  width={Math.round(height * (866.60 / 132))}
  alt={ariaLabel}
  decoding="async"
/>

<style>
  .mc-wordmark-compact { display: block; }
</style>
