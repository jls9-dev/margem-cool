---
import '../styles/tokens.css';
import '../styles/base.css';

import WordmarkCompact from '../components/brand/WordmarkCompact.astro';
import Wordmark from '../components/brand/Wordmark.astro';
import { PRIMARY_NAV, FOOTER_NAV, htmlLang, SITE_URL, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  /** Path of the equivalent page in the other language, e.g. '/en/' or '/'. */
  alternateUrl?: string;
  /** Canonical path of this page, relative to the site root. */
  canonicalPath?: string;
  /** Optional Schema.org JSON-LD object to inject as a single script tag. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  lang,
  title,
  description,
  alternateUrl,
  canonicalPath = Astro.url.pathname,
  jsonLd,
} = Astro.props;

const nav = PRIMARY_NAV[lang];
const footerNav = FOOTER_NAV[lang];
const otherLang: Lang = lang === 'pt' ? 'en' : 'pt';
const canonical = new URL(canonicalPath, SITE_URL).toString();
const alternate = alternateUrl
  ? new URL(alternateUrl, SITE_URL).toString()
  : undefined;

const secondaryTagline = lang === 'pt' ? 'O outro lado' : 'The other side';
const copyrightLabel = `© ${new Date().getFullYear()} Margem Cool`;
---

<!doctype html>
<html lang={htmlLang(lang)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="canonical" href={canonical} />
    {alternate && (
      <>
        <link rel="alternate" hreflang={htmlLang(otherLang)} href={alternate} />
        <link rel="alternate" hreflang={htmlLang(lang)} href={canonical} />
        <link rel="alternate" hreflang="x-default" href={lang === 'pt' ? canonical : alternate} />
      </>
    )}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={htmlLang(lang).replace('-', '_')} />
    {alternate && (
      <meta property="og:locale:alternate" content={htmlLang(otherLang).replace('-', '_')} />
    )}

    <meta name="twitter:card" content="summary_large_image" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'pt' ? 'Saltar para o conteúdo' : 'Skip to content'}</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href={lang === 'pt' ? '/' : '/en/'} aria-label="Margem Cool">
          <WordmarkCompact height={36} />
        </a>

        <button
          class="site-nav-toggle"
          type="button"
          aria-controls="primary-nav"
          aria-expanded="false"
          aria-label={lang === 'pt' ? 'Abrir menu' : 'Open menu'}
          data-label-open={lang === 'pt' ? 'Abrir menu' : 'Open menu'}
          data-label-close={lang === 'pt' ? 'Fechar menu' : 'Close menu'}
        >
          <span class="site-nav-toggle__bars" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
        </button>

        <nav
          id="primary-nav"
          class="site-nav"
          aria-label={lang === 'pt' ? 'Navegação principal' : 'Primary navigation'}
        >
          <ul>
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={Astro.url.pathname === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
          {alternate && (
            <a class="lang-switch smallcaps" href={alternate} hreflang={htmlLang(otherLang)}>
              {otherLang === 'pt' ? 'PT' : 'EN'}
            </a>
          )}
        </nav>
      </div>
    </header>

    <script>
      // Mobile nav toggle. Closes on link click, Escape, and outside click.
      (function () {
        const toggle = document.querySelector('.site-nav-toggle');
        const nav = document.getElementById('primary-nav');
        if (!toggle || !nav) return;

        const setOpen = (open) => {
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          toggle.setAttribute(
            'aria-label',
            open
              ? toggle.dataset.labelClose || 'Close menu'
              : toggle.dataset.labelOpen || 'Open menu'
          );
        };

        toggle.addEventListener('click', () => {
          const isOpen = toggle.getAttribute('aria-expanded') === 'true';
          setOpen(!isOpen);
        });

        nav.addEventListener('click', (e) => {
          if (e.target instanceof HTMLAnchorElement) setOpen(false);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
            setOpen(false);
            toggle.focus();
          }
        });

        document.addEventListener('click', (e) => {
          if (toggle.getAttribute('aria-expanded') !== 'true') return;
          const target = e.target;
          if (!(target instanceof Node)) return;
          if (toggle.contains(target) || nav.contains(target)) return;
          setOpen(false);
        });
      })();
    </script>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <nav class="site-footer__columns" aria-label={lang === 'pt' ? 'Rodapé' : 'Footer'}>
          <div class="site-footer__col">
            <h2 class="site-footer__col-h smallcaps">{footerNav.pillars.heading}</h2>
            <ul>
              {footerNav.pillars.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="site-footer__col">
            <h2 class="site-footer__col-h smallcaps">{footerNav.publication.heading}</h2>
            <ul>
              {footerNav.publication.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        </nav>

        <div class="site-footer__signature">
          <div class="site-footer__brand">
            <Wordmark size={180} />
            <p class="site-footer__tagline smallcaps">{secondaryTagline}</p>
          </div>
          <p class="site-footer__meta">{copyrightLabel}</p>
        </div>
      </div>
    </footer>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-text);
        color: var(--color-background);
        padding: var(--space-xs) var(--space-sm);
        z-index: 100;
        border-bottom: 0;
      }
      .skip-link:focus { left: var(--space-sm); top: var(--space-sm); }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        padding: 14px 0;
        background: color-mix(in srgb, var(--color-background) 92%, transparent);
        backdrop-filter: saturate(140%) blur(8px);
        -webkit-backdrop-filter: saturate(140%) blur(8px);
        border-bottom: 1px solid var(--color-rule);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        min-height: 40px;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 clamp(16px, 3vw, 40px);
      }
      .site-header__brand {
        border-bottom: 0;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
      }

      .site-nav {
        flex: 1;
        min-width: 0;
        display: flex;
        align-items: center;
        gap: var(--space-md);
        justify-content: flex-end;
      }
      .site-nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--space-sm);
        flex-wrap: nowrap;
        justify-content: flex-end;
      }
      .site-nav a {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 12px;
        letter-spacing: var(--tracking-smallcaps);
        text-transform: uppercase;
        border-bottom: 0;
        color: var(--color-text);
        white-space: nowrap;
      }
      .site-nav a[aria-current="page"] { color: var(--color-accent); }
      .site-nav a:hover { color: var(--color-accent); }

      .lang-switch {
        flex-shrink: 0;
        border: 1px solid var(--color-rule);
        padding: 4px 8px;
        font-size: 11px;
      }
      .lang-switch:hover { border-color: var(--color-accent); }

      /* Hamburger button — hidden on desktop, shown on mobile */
      .site-nav-toggle {
        display: none;
        margin-left: auto;
        background: transparent;
        border: 0;
        padding: 8px;
        cursor: pointer;
        color: var(--color-text);
      }
      .site-nav-toggle:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }
      .site-nav-toggle__bars {
        display: inline-flex;
        flex-direction: column;
        gap: 4px;
        width: 22px;
      }
      .site-nav-toggle__bars span {
        display: block;
        height: 2px;
        background: currentColor;
        transition: transform 200ms ease, opacity 200ms ease;
        transform-origin: center;
      }
      .site-nav-toggle[aria-expanded="true"] .site-nav-toggle__bars span:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
      }
      .site-nav-toggle[aria-expanded="true"] .site-nav-toggle__bars span:nth-child(2) {
        opacity: 0;
      }
      .site-nav-toggle[aria-expanded="true"] .site-nav-toggle__bars span:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
      }

      @media (max-width: 720px) {
        .site-header { padding: 10px 0; }

        .site-nav-toggle { display: inline-flex; align-items: center; }

        /* Nav becomes a drop-down panel anchored below the header bar */
        .site-nav {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: var(--color-background);
          border-bottom: 1px solid var(--color-rule);
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          padding: var(--space-md) clamp(16px, 3vw, 40px) var(--space-lg);
        }
        .site-nav-toggle[aria-expanded="true"] ~ .site-nav { display: flex; }

        .site-nav ul {
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          justify-content: flex-start;
          width: 100%;
        }
        .site-nav li {
          border-bottom: 1px solid var(--color-rule);
        }
        .site-nav li:last-child { border-bottom: 0; }
        .site-nav a {
          display: block;
          padding: 14px 0;
          font-size: 14px;
        }
        .site-nav .lang-switch {
          align-self: flex-start;
          margin-top: var(--space-md);
          padding: 6px 12px;
          font-size: 12px;
        }
      }

      .site-footer {
        margin-top: var(--space-3xl);
        padding: var(--space-2xl) 0 var(--space-xl);
        background: color-mix(in srgb, var(--mc-cream) 78%, var(--mc-cool-grey) 12%);
      }
      @media (prefers-color-scheme: dark) {
        .site-footer {
          background: color-mix(in srgb, var(--mc-charcoal) 82%, var(--mc-cool-grey-dark) 14%);
        }
      }
      .site-footer__inner {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
      }

      .site-footer__columns {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: var(--space-xl);
        max-width: var(--wide-section);
      }
      .site-footer__col-h {
        margin: 0 0 var(--space-md);
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 11px;
        letter-spacing: var(--tracking-masthead);
        color: var(--color-text-secondary);
      }
      .site-footer__col ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
      }
      .site-footer__col a {
        font-family: var(--font-body);
        font-size: var(--type-small);
        border-bottom: 0;
        color: var(--color-text);
      }
      .site-footer__col a:hover { color: var(--color-accent); }

      .site-footer__signature {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-md);
        flex-wrap: wrap;
        padding-top: var(--space-lg);
        border-top: 1px solid var(--color-rule);
      }
      .site-footer__brand {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
      }
      @media (max-width: 720px) {
        .site-footer__brand :global(svg) {
          width: 130px;
          height: auto;
        }
      }
      .site-footer__tagline {
        margin: 0;
        font-size: var(--type-masthead-meta);
        letter-spacing: var(--tracking-masthead);
        color: var(--color-text-secondary);
      }
      .site-footer__meta {
        margin: 0;
        font-family: var(--font-display);
        font-size: var(--type-caption);
        color: var(--color-text-secondary);
      }
    </style>
  </body>
</html>
