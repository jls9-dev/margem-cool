---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MargemSulMark from '../../components/brand/MargemSulMark.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About · Margem Cool',
  inLanguage: 'en',
  url: 'https://margemcool.pt/en/about/',
};
---

<BaseLayout
  lang="en"
  title="About · Margem Cool"
  description="Margem Cool is a publication of the Margem Sul, written from where we live, in Portuguese and English."
  alternateUrl="/sobre/"
  canonicalPath="/en/about/"
  jsonLd={jsonLd}
>
  <article class="about">
    <div class="container">
      <header class="about__head">
        <div class="about__mark" aria-hidden="true">
          <MargemSulMark size={260} variant="outline" ariaHidden />
        </div>
        <div class="about__intro">
          <p class="about__kicker smallcaps">About</p>
          <h1 class="about__title">
            What you're reading <span class="about__title-em">covers this shape.</span>
          </h1>
          <p class="about__lede">
            Margem Cool is a publication of the Margem Sul — the nine concelhos south
            of the Tagus, from Almada to Alcochete, from the Costa da Caparica to the
            Arrábida. Written from where we live, in Portuguese and English.
          </p>
        </div>
      </header>

      <div class="about__body">
        <p>
          The shape beside us is the silhouette of the nine concelhos taken together —
          Almada, Seixal, Sesimbra, Setúbal, Palmela, Barreiro, Moita, Montijo and
          Alcochete. It's both the map of what we cover and the edge of what we cover.
          Anything inside it can appear here; anything outside doesn't.
        </p>
        <p>
          We work slowly, piece by piece. We started with the places — a freguesia here,
          a bairro there — and we're moving into themes: eat and drink, beach and nature,
          culture and agenda, sleep, living here. We don't do snap guides. When a place
          or a freguesia appears here, the work has been done.
        </p>
        <p>
          Most of the writing is in Portuguese first, with an English version following.
          The register is the second-person familiar — we're talking with neighbours and
          the curious, not with a standard tourist. If you know the Margem Sul from the
          inside you'll recognise yourself; if you want to know it better, there are no
          filters here.
        </p>
        <p class="about__tagline smallcaps">The other side</p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .about__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-2xl);
    align-items: center;
    max-width: var(--wide-section);
    margin: 0 auto var(--space-2xl);
  }
  @media (max-width: 820px) {
    .about__head {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
  .about__intro {
    max-width: 50ch;
  }
  .about__mark {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    line-height: 0;
  }
  .about__mark :global(.ms-mark--outline path) {
    stroke-width: 5;
    stroke: var(--color-accent);
    opacity: 0.85;
  }
  @media (max-width: 820px) {
    .about__mark {
      grid-column: 1;
      justify-self: center;
    }
  }

  .about__kicker {
    margin: 0 0 var(--space-md);
    color: var(--color-accent);
    font-size: var(--type-caption);
  }
  .about__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-md);
  }
  .about__title-em {
    font-style: italic;
    color: var(--color-accent);
  }
  .about__lede {
    font-family: var(--font-body);
    font-size: var(--type-lead);
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .about__body {
    max-width: var(--content-column);
    margin: 0 auto;
    font-family: var(--font-body);
    font-size: var(--type-body);
    line-height: 1.6;
  }
  .about__body p {
    margin: 0 0 var(--space-md);
  }
  .about__tagline {
    margin-top: var(--space-2xl);
    color: var(--color-accent);
    font-size: var(--type-caption);
  }
</style>
